    <script>

$(document).ready(function () {

    const table = $('#transactionsTable').DataTable({
        processing: true,
        serverSide: true,
        searching: false, // use custom filters
        ajax: {
            url: '/transactions/filter',
            type: 'POST',
            contentType: 'application/json',
            data: function (d) {
                return JSON.stringify({
                    ...d,
                    startDate: $('#startDate').val(),
                    endDate: $('#endDate').val(),
                    memberStatus: $('#memberStatus').val(),
                    memberId: $('#memberId').val(),
                    transaction_type: $('#transaction_type').val(),
                    payment_period: $('#payment_period').val()
                });
            },
            error: function(xhr, error, thrown) {
                Swal.fire({
                    icon: 'error',
                    title: 'Ajax Error',
                    text: xhr.responseJSON?.error || 'Could not load data.'
                });
            }
        },
        columns: [
            { data: 'id' },
            { data: 'member_id' },
            { 
                data: 'tran_date',
                render: function (data) {
                    return data ? new Date(data).toLocaleDateString('en-GB') : '';
                }
            },
            { 
                data: 'Amount',
                render: function (data, type, row) {
                    const typeStr = row.debit_credit ? row.debit_credit.toLowerCase() : '';
                    const color = typeStr === 'credit' ? 'green' : 'red';
                    return `<span style="color:${color}; font-weight:bold;">UGX ${parseInt(data,10).toLocaleString()}</span>`;
                }
            },
            { data: 'payment_period' },
            { data: 'transaction_type' },
            { data: 'description' },
            { data: 'debit_credit' }
        ]
    });

    // Reload table when filter button clicked
    $('#filterBtn').on('click', function () {
        table.ajax.reload();
    });

});

</script>
