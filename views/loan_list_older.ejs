<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Loans Management</title>
    <link href="./assets/vendors/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="./assets/vendors/font-awesome/css/font-awesome.min.css" rel="stylesheet" />
    <link href="./assets/vendors/themify-icons/css/themify-icons.css" rel="stylesheet" />
    <link href="./assets/vendors/DataTables/datatables.min.css" rel="stylesheet" />
    <link href="assets/css/main.min.css" rel="stylesheet" />
    <style>
        /* ── Page chrome ── */
        .page-heading        { padding: 6px 0 4px; }
        .page-title          { font-size: 16px; margin-bottom: 2px; }
        .breadcrumb          { padding: 2px 0; margin: 0; font-size: 11px; }
        .ibox-head           { padding: 7px 12px; }
        .ibox-body           { padding: 8px; }
        .ibox-title          { font-size: 13px; }

        /* ── Filter bar ── */
        .filter-section               { background:#f8f9fa; padding:8px 10px; border-radius:4px; margin-bottom:8px; }
        .filter-section label         { font-size:10px; font-weight:600; margin-bottom:1px; display:block; }
        .filter-section .form-control { height:26px; font-size:11px; padding:2px 6px; }

        /* ── Table ── */
        #loansTable                   { font-size: 11px; }
        #loansTable thead th          {  font-size: 8px; white-space: nowrap;
                                        background: #343a40; color: #fff; border-color: #454d55;
                                        vertical-align: middle; line-height: 1.2; }
        #loansTable tbody td          { padding: 4px 3px; vertical-align: middle; line-height: 1.2; }
        #loansTable tbody tr:hover td { background: #f0f4ff; }

        /* ── Action buttons ── */
        .btn-group-xs .btn            { padding: 2px 5px; font-size: 10px; line-height: 1.4; }

        /* ── Badges ── */
        .badge                        { font-size: 9px; padding: 2px 5px; border-radius: 3px; }

        /* ── DataTables chrome ── */
        .dataTables_wrapper .dataTables_length,
        .dataTables_wrapper .dataTables_filter,
        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_paginate { font-size: 11px; }
        .dataTables_wrapper .dataTables_length select { height:24px; font-size:11px; padding:0 4px; }
        .dataTables_wrapper .dataTables_filter input { height:24px; font-size:11px; padding:2px 6px; }
        .dataTables_wrapper .dataTables_paginate .paginate_button { padding:2px 7px !important; font-size:11px !important; }

        /* ── Number alignment ── */
        .text-right  { text-align: right !important; }
        .text-center { text-align: center !important; }

        /* ── Interest modal ── */
        .interest-summary-card      { background:#f8f9fa; border-radius:6px; padding:8px 10px; margin-bottom:8px; font-size:12px; }
        .interest-summary-card .lbl { font-size:10px; color:#666; font-weight:600; }
        .interest-summary-card .val { font-size:13px; font-weight:700; }
        .interest-table             { font-size: 11px; }
        .interest-table th          { background:#343a40; color:#fff; padding:4px 6px; font-size:10px; }
        .interest-table td          { padding:3px 6px; }
    </style>
</head>

<body class="fixed-navbar">
<div class="page-wrapper">
    <%- include('partials/header') %>
    <%- include('partials/sidebar') %>

    <div class="content-wrapper">
        <div class="page-heading">
            <h1 class="page-title">Loans Management</h1>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/"><i class="la la-home font-20"></i></a></li>
                <li class="breadcrumb-item">Loans List</li>
            </ol>
        </div>

        <div class="page-content fade-in-up">
            <div class="ibox">
                <div class="ibox-head">
                    <div class="ibox-title">All Loans</div>
                    <div class="ibox-tools">
                        <a href="/loan_application" class="btn btn-primary btn-xs">
                            <i class="fa fa-plus"></i> New Loan
                        </a>
                    </div>
                </div>

                <div class="ibox-body">
                    <!-- Filter bar -->
                    <div class="filter-section">
                        <div class="row" style="align-items:flex-end;">
                            <div class="col-md-2 col-sm-6">
                                <label>Member ID</label>
                                <input type="text" id="memberId" placeholder="ID" class="form-control">
                            </div>
                            <div class="col-md-3 col-sm-6">
                                <label>Member Name</label>
                                <input type="text" id="memberName" placeholder="Name" class="form-control">
                            </div>
                            <div class="col-md-2 col-sm-4">
                                <label>Status</label>
                                <select id="loanStatus" class="form-control">
                                    <option value="">All</option>
                                    <option value="Active">Active</option>
                                    <option value="Pending">Pending</option>
                                    <option value="Completed">Completed</option>
                                    <option value="Defaulted">Defaulted</option>
                                </select>
                            </div>
                            <div class="col-md-2 col-sm-4">
                                <button id="filterBtn" class="btn btn-primary btn-sm btn-block" style="height:26px;font-size:11px;padding:2px 8px;">
                                    <i class="fa fa-filter"></i> Filter
                                </button>
                            </div>
                            <div class="col-md-2 col-sm-4">
                                <button id="clearBtn" class="btn btn-secondary btn-sm btn-block" style="height:26px;font-size:11px;padding:2px 8px;">
                                    <i class="fa fa-refresh"></i> Clear
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Table -->
                    <div class="table-responsive">
                        <table id="loansTable" class="table table-striped table-bordered table-hover nowrap" style="width:100%">
                            <thead>
                                <tr>
                                    <th style="width:35px">ID</th>
                                    <th style="width:35px">M.ID</th>
                                    <th style="width:110px">Name</th>
                                    <th style="width:75px" class="text-right">Amount</th>
                                    <th style="width:40px" class="text-right">Rate</th>
                                    <th style="width:38px" class="text-center">Term</th>
                                    <th style="width:75px" class="text-right">Monthly</th>
                                    <th style="width:75px" class="text-right">Balance</th>
                                    <th style="width:75px" class="text-right">Accrued</th>
                                    <th style="width:68px" class="text-center">Disbursed</th>
                                    <th style="width:62px" class="text-center">Status</th>
                                    <th style="width:80px" class="text-center">Actions</th>
                                </tr>
                            </thead>
                        </table>
                    </div>
                </div>
            </div>
        </div>

        <footer class="page-footer">
            <div class="font-13">2025 © <b>Fincas</b> - All rights reserved.</div>
        </footer>
    </div>
</div>

<script src="./assets/vendors/jquery/dist/jquery.min.js"></script>
<script src="./assets/vendors/popper.js/dist/umd/popper.min.js"></script>
<script src="./assets/vendors/bootstrap/dist/js/bootstrap.min.js"></script>
<script src="./assets/vendors/metisMenu/dist/metisMenu.min.js"></script>
<script src="./assets/vendors/jquery-slimscroll/jquery.slimscroll.min.js"></script>
<script src="./assets/vendors/DataTables/datatables.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="assets/js/app.min.js"></script>

<script>
$(document).ready(function () {

    var table = $('#loansTable').DataTable({
        processing: true,
        serverSide: true,
        scrollX: true,
        autoWidth: false,
        dom: '<"row mb-1"<"col-sm-5"l><"col-sm-7"f>>rt<"row mt-1"<"col-sm-5"i><"col-sm-7"p>>',
        ajax: {
            url: '/loans/list',
            type: 'POST',
            data: function (d) {
                d.memberId   = $('#memberId').val();
                d.memberName = $('#memberName').val();
                d.loanStatus = $('#loanStatus').val();
            }
        },
        order: [[0, 'desc']],
        pageLength: 25,
        lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
        columns: [
            { data: 'loan_id',         width: '35px', className: 'text-center' },
            { data: 'member_id',        width: '35px', className: 'text-center' },
            { data: 'member_name',      width: '110px' },
            {
                data: 'loan_amount', width: '75px', className: 'text-right',
                render: d => parseFloat(d).toLocaleString('en-UG', { maximumFractionDigits: 0 })
            },
            {
                data: 'interest_rate', width: '40px', className: 'text-right',
                render: d => parseFloat(d).toFixed(1) + '%'
            },
            {
                data: 'loan_term_months', width: '38px', className: 'text-center',
                render: d => d + 'm'
            },
            {
                data: 'monthly_payment', width: '75px', className: 'text-right',
                render: d => parseFloat(d).toLocaleString('en-UG', { maximumFractionDigits: 0 })
            },
            {
                data: 'balance', width: '75px', className: 'text-right',
                render: function (d) {
                    const v = parseFloat(d);
                    const f = v.toLocaleString('en-UG', { maximumFractionDigits: 0 });
                    return v > 0 ? `<span class="text-danger font-weight-bold">${f}</span>` : f;
                }
            },
            {
                data: 'accumulated_interest', width: '75px', className: 'text-right',
                render: d => parseFloat(d).toLocaleString('en-UG', { maximumFractionDigits: 0 })
            },
            {
                data: 'disbursement_date', width: '68px', className: 'text-center',
                render: d => new Date(d).toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: '2-digit' })
            },
            {
                data: 'status', width: '62px', className: 'text-center',
                render: function (d) {
                    const map = { Active: 'success', Completed: 'primary', Defaulted: 'danger', Pending: 'warning' };
                    return `<span class="badge badge-${map[d] || 'secondary'}">${d}</span>`;
                }
            },
            {
                data: null, orderable: false, width: '80px', className: 'text-center',
                render: function (d, t, row) {
                    return `
                    <div class="btn-group btn-group-xs" role="group">
                        <a href="/Loan_statement?loan_id=${row.loan_id}"
                           class="btn btn-info" title="Statement">
                            <i class="fa fa-file-text"></i>
                        </a>
                        <a href="/loan_repayment?loan_id=${row.loan_id}"
                           class="btn btn-success" title="Payment">
                            <i class="fa fa-money"></i>
                        </a>
                        <button class="btn btn-primary view-interest-btn"
                                data-loan-id="${row.loan_id}"
                                data-member-name="${row.member_name}"
                                title="Interest">
                            <i class="fa fa-line-chart"></i>
                        </button>
                    </div>`;
                }
            }
        ]
    });

    /* ── Filters ── */
    $('#filterBtn').on('click', () => table.ajax.reload());
    $('#clearBtn').on('click', function () {
        $('#memberId, #memberName').val('');
        $('#loanStatus').val('');
        table.ajax.reload();
    });

    /* ── Interest history modal ── */
    $(document).on('click', '.view-interest-btn', function () {
        viewInterestHistory($(this).data('loan-id'), $(this).data('member-name'));
    });
});

/* ─────────────────────────────────────────
   Interest History
───────────────────────────────────────── */
function viewInterestHistory(loanId, memberName) {
    Swal.fire({ title: 'Loading…', allowOutsideClick: false, didOpen: () => Swal.showLoading() });

    fetch(`/loans/${loanId}/interest-history?limit=90`)
        .then(r => r.json())
        .then(data => displayInterestModal(loanId, memberName, data.history))
        .catch(() => Swal.fire({ icon: 'error', title: 'Error', text: 'Failed to load interest history' }));
}

function displayInterestModal(loanId, memberName, history) {
    if (!history || !history.length) {
        return Swal.fire({ icon: 'info', title: 'No Interest History', text: 'No daily calculations found.' });
    }

    const totalInt  = history.reduce((s, r) => s + parseFloat(r.daily_interest_amount), 0);
    const avgBal    = history.reduce((s, r) => s + parseFloat(r.outstanding_balance), 0) / history.length;
    const fmt       = (n, d = 0) => parseFloat(n).toLocaleString('en-UG', { maximumFractionDigits: d, minimumFractionDigits: d });

    /* Summary row */
    const summary = `
        <div class="interest-summary-card">
            <div class="mb-1"><strong>Loan #${loanId}</strong> &mdash; ${memberName}</div>
            <div class="row text-center">
                <div class="col-4">
                    <div class="lbl">Days Tracked</div>
                    <div class="val text-primary">${history.length}</div>
                </div>
                <div class="col-4">
                    <div class="lbl">Total Interest</div>
                    <div class="val text-success">${fmt(totalInt, 0)}</div>
                </div>
                <div class="col-4">
                    <div class="lbl">Avg Balance</div>
                    <div class="val text-info">${fmt(avgBal, 0)}</div>
                </div>
            </div>
        </div>`;

    /* Table rows */
    const rows = history.map(r => `
        <tr>
            <td>${new Date(r.calculation_date).toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'2-digit' })}</td>
            <td class="text-right">${fmt(r.outstanding_balance)}</td>
            <td class="text-right">${fmt(r.daily_interest_amount, 2)}</td>
            <td class="text-right">${parseFloat(r.annual_interest_rate).toFixed(1)}%</td>
        </tr>`).join('');

    const html = `
        ${summary}
        <div style="max-height:380px;overflow-y:auto;">
            <table class="table table-sm table-striped table-bordered interest-table mb-0">
                <thead>
                    <tr>
                        <th>Date</th>
                        <th class="text-right">Balance</th>
                        <th class="text-right">Interest</th>
                        <th class="text-right">Rate</th>
                    </tr>
                </thead>
                <tbody>${rows}</tbody>
            </table>
        </div>
        <div class="mt-2 text-center">
            <button onclick="exportInterestHistory(${loanId})" class="btn btn-sm btn-success mr-1">
                <i class="fa fa-download"></i> Export CSV
            </button>
            <button onclick="viewFullInterestHistory(${loanId})" class="btn btn-sm btn-primary">
                <i class="fa fa-expand"></i> View All
            </button>
        </div>`;

    Swal.fire({
        title: 'Daily Interest History',
        html: html,
        width: '680px',
        showConfirmButton: true,
        confirmButtonText: 'Close',
        customClass: { popup: 'text-left' }
    });
}

function viewFullInterestHistory(loanId) {
    window.open(`/loans/${loanId}/interest-full`, '_blank');
}

function exportInterestHistory(loanId) {
    window.location.href = `/loans/${loanId}/interest-export`;
}
</script>
</body>
</html>
