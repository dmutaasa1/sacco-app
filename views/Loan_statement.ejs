<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width initial-scale=1.0">
    <title>Loan Statement</title>
    <link href="./assets/vendors/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="./assets/vendors/font-awesome/css/font-awesome.min.css" rel="stylesheet" />
    <link href="./assets/vendors/themify-icons/css/themify-icons.css" rel="stylesheet" />
    <link href="assets/css/main.min.css" rel="stylesheet" />
    <style>
        .loan-summary {
            background: #f8f9fa;
            padding: 20px;
            border-radius: 5px;
            margin-bottom: 20px;
        }
        .summary-item {
            display: flex;
            justify-content: space-between;
            padding: 10px 0;
            border-bottom: 1px solid #dee2e6;
        }
        .summary-item:last-child {
            border-bottom: none;
        }
        .payment-status-paid {
            background: #28a745;
            color: white;
            padding: 3px 8px;
            border-radius: 3px;
            font-size: 0.85rem;
        }
        .payment-status-pending {
            background: #ffc107;
            color: black;
            padding: 3px 8px;
            border-radius: 3px;
            font-size: 0.85rem;
        }
        .payment-status-overdue {
            background: #dc3545;
            color: white;
            padding: 3px 8px;
            border-radius: 3px;
            font-size: 0.85rem;
        }

        .table_text {
            font-size: 0.9rem;        
            }


        
    </style>
</head>

<body class="fixed-navbar">
    <div class="page-wrapper">
        <%- include('partials/header') %>
        <%- include('partials/sidebar') %>
        
        <div class="content-wrapper">
            <div class="page-heading">
                <h1 class="page-title">Loan Statement</h1>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="index.html"><i class="la la-home font-20"></i></a>
                    </li>
                    <li class="breadcrumb-item">Loans</li>
                    <li class="breadcrumb-item">Statement</li>
                </ol>
            </div>
            
            <div class="page-content fade-in-up">
                <div class="ibox">
                    <div class="ibox-head">
                        <div class="ibox-title">Loan Summary</div>
                        <div class="ibox-tools">
                            <button class="btn btn-primary btn-sm" onclick="window.print()">
                                <i class="fa fa-print"></i> Print Statement
                            </button>
                        </div>
                    </div>
                    <div class="ibox-body">
                        <div class="loan-summary" id="loanSummary">
                            <p class="text-center text-muted">Loading loan details...</p>
                        </div>

                        <h4>Payment Schedule</h4>
                        <div class="table-responsive">
                            <table class="table table-striped table-bordered" id="scheduleTable">
                                <thead>
                                    <tr>
                                        <th>Payment #</th>
                                        <th>Due Date</th>
                                        <th>Principal</th>
                                        <th>Interest</th>
                                        <th>Total Payment</th>
                                        <th>Balance After</th>
                                        <th>Paid Date</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody id="scheduleBody">
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            
            <footer class="page-footer">
                <div class="font-13">2025 © <b>Fincas</b> - All rights reserved.</div>
                <a class="px-4" href="#" target="_blank">Contact Us</a>
                <div class="to-top"><i class="fa fa-angle-double-up"></i></div>
            </footer>
        </div>
    </div>

    <script src="./assets/vendors/jquery/dist/jquery.min.js"></script>
    <script src="./assets/vendors/popper.js/dist/umd/popper.min.js"></script>
    <script src="./assets/vendors/bootstrap/dist/js/bootstrap.min.js"></script>
    <script src="./assets/vendors/metisMenu/dist/metisMenu.min.js"></script>
    <script src="./assets/vendors/jquery-slimscroll/jquery.slimscroll.min.js"></script>
    <script src="assets/js/app.min.js"></script>

    
    <script>


/* =========================
   GET LOAN ID
========================= */
const urlParams = new URLSearchParams(window.location.search);
const loanId = urlParams.get('loan_id');

if (!loanId) {
    alert('No loan ID provided');
    window.location.href = '/loans_list';
}

/* =========================
   DISPLAY PAYMENT SCHEDULE
========================= */
function displaySchedule(schedule) {
    let html = '<div class="table-responsive">';
    html += '<table class="table table-bordered table-hover">';
    html += `<thead class="thead-light">
        <tr>
            <th style="width: 10px;">#</th>
            <th>Due Date</th>
            <th>Expected Payment</th>
            <th>Expected Principal</th>
            <th>Expected Interest</th>
            <th>Amount Paid</th>
            <th>Balance</th>
            <th>Status</th>
            <th>Paid Date</th>
        </tr>
    </thead><tbody>`;

    let totalExpectedPayment = 0;
    let totalExpectedPrincipal = 0;
    let totalExpectedInterest = 0;
    let totalPaid = 0;

    schedule.forEach(s => {
        const expectedPayment = parseFloat(s.expected_payment || 0);
        const expectedPrincipal = parseFloat(s.expected_principal || 0);
        const expectedInterest = parseFloat(s.expected_interest || 0);
        const paidAmount = parseFloat(s.paid_amount || 0);
        const balance = expectedPayment - paidAmount;

        totalExpectedPayment += expectedPayment;
        totalExpectedPrincipal += expectedPrincipal;
        totalExpectedInterest += expectedInterest;
        totalPaid += paidAmount;

        let statusBadge = '';
        let rowClass = '';

        if (s.status === 'Paid') {
            statusBadge = '<span class="badge badge-success">Paid</span>';
            rowClass = 'table-success';
        } else if (s.status === 'Overdue') {
            statusBadge = '<span class="badge badge-danger">Overdue</span>';
            rowClass = 'table-danger';
        } else {
            statusBadge = '<span class="badge badge-warning">Pending</span>';
        }

        html += `
            <tr class="${rowClass} table_text">
                <td  style="width: 10px;">${s.payment_number}</td>
                <td>${new Date(s.due_date).toLocaleDateString('en-GB')}</td>
                <td>UGX ${expectedPayment.toLocaleString()}</td>
                <td>UGX ${expectedPrincipal.toLocaleString()}</td>
                <td>UGX ${expectedInterest.toLocaleString()}</td>
                <td>UGX ${paidAmount.toLocaleString()}</td>
                <td>UGX ${balance.toLocaleString()}</td>
                <td>${statusBadge}</td>
                <td>${s.paid_date ? new Date(s.paid_date).toLocaleDateString('en-GB') : '-'}</td>
            </tr>
        `;
    });

    html += `
        <tr class="table-info font-weight-bold">
            <td colspan="2">TOTALS</td>
            <td>UGX ${totalExpectedPayment.toLocaleString()}</td>
            <td>UGX ${totalExpectedPrincipal.toLocaleString()}</td>
            <td>UGX ${totalExpectedInterest.toLocaleString()}</td>
            <td>UGX ${totalPaid.toLocaleString()}</td>
            <td>UGX ${(totalExpectedPayment - totalPaid).toLocaleString()}</td>
            <td colspan="2"></td>
        </tr>
    `;

    html += '</tbody></table>';
    html += `
        <div class="alert alert-info mt-3">
            <i class="fa fa-info-circle"></i>
            <strong>Note:</strong>
            Expected interest is calculated using the reducing balance method.
            Actual interest is calculated daily on the outstanding balance.
        </div>
    `;
    html += '</div>';

    $('#scheduleTable').html(html);
}

/* =========================
   LOAD LOAN STATEMENT
========================= */
$.ajax({
    url: `/loans/${loanId}/statement`,
    type: 'GET',
    success: function(response) {
        const loan = response.loan;
        const schedule = response.schedule;

        /* ===== LOAN SUMMARY ===== */
        const summaryHtml = `
            <div class="summary-item"><span>Loan ID:</span><strong>${loan.id}</strong></div>
            <div class="summary-item"><span>Member:</span><strong>${loan.member_name}</strong></div>
            <div class="summary-item"><span>Loan Amount:</span><strong>UGX ${parseFloat(loan.loan_amount).toLocaleString()}</strong></div>
            <div class="summary-item"><span>Interest Rate:</span><strong>${loan.interest_rate}% per annum</strong></div>
            <div class="summary-item"><span>Loan Term:</span><strong>${loan.loan_term_months} months</strong></div>
            <div class="summary-item"><span>Monthly Payment:</span><strong>UGX ${parseFloat(loan.monthly_payment).toLocaleString()}</strong></div>
            <div class="summary-item"><span>Total Interest:</span><strong>UGX ${parseFloat(loan.total_interest).toLocaleString()}</strong></div>
            <div class="summary-item"><span>Total Repayment:</span><strong>UGX ${parseFloat(loan.total_repayment).toLocaleString()}</strong></div>
            <div class="summary-item">
                <span>Current Balance:</span>
                <strong style="color:${loan.balance > 0 ? 'red' : 'green'};">
                    UGX ${parseFloat(loan.balance).toLocaleString()}
                </strong>
            </div>
            <div class="summary-item"><span>Status:</span><strong>${loan.status}</strong></div>
        `;

        $('#loanSummary').html(summaryHtml);

        /* ===== PAYMENT SCHEDULE ===== */
        displaySchedule(schedule);
    },
    error: function() {
        alert('Error loading loan statement');
        window.location.href = 'loans-list.html';
    }
});



</script>



</body>
</html>