    <!-- PAGE LEVEL SCRIPTS-->
   
    <script>
        $(document).ready(function () {
            const table = $('#paymentStatusTable').DataTable({
                processing: true,
                serverSide: true,
                searching: false,
                ajax: {
                    url: '/welfare/payment-status',
                    type: 'POST',
                    contentType: 'application/json',
                    data: function (d) {
                        return JSON.stringify({
                            ...d,
                            payment_period: $('#payment_period').val(),
                            memberStatus: $('#memberStatus').val(),
                            paymentStatus: $('#paymentStatus').val()
                        });
                    },
                    error: function(xhr, error, thrown) {
                        alert('Error: ' + (xhr.responseJSON?.error || 'Could not load data.'));
                    }
                },
                columns: [
                    { data: 'member_id' },
                    { data: 'First_name' },
                    { data: 'Last_Name' },
                    { data: 'tel_no' },
                    { 
                        data: 'Date_Joined',
                        render: function (data) {
                            return data ? new Date(data).toLocaleDateString('en-GB') : '';
                        }
                    },
                    { 
                        data: 'Status',
                        render: function (data) {
                            const color = data === 'Active' ? 'green' : 'red';
                            return `<span style="color:${color}; font-weight:bold;">${data}</span>`;
                        }
                    },
                    { 
                        data: 'Total_Amount',
                        render: function (data) {
                            return `UGX ${parseInt(data, 10).toLocaleString()}`;
                        }
                    },
                    { 
                        data: 'last_payment_date',
                        render: function (data) {
                            return data ? new Date(data).toLocaleDateString('en-GB') : 'N/A';
                        }
                    },
                    { data: 'last_payment_period' },
                    { 
                        data: 'Payment_Status',
                        render: function (data) {
                            const color = data === 'Paid' ? 'green' : 'red';
                            const icon = data === 'Paid' ? '✓' : '✗';
                            return `<span style="color:${color}; font-weight:bold;">${icon} ${data}</span>`;
                        }
                    }
                ]
            });

            // Reload table when filter button clicked
            $('#filterBtn').on('click', function () {
                table.ajax.reload();
            });
        });
    </script>
