<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Forgot Password</title>
    <link href="/assets/vendors/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6">
                <div class="card">
                    <div class="card-header">
                        <h4>Forgot Password</h4>
                    </div>
                    <div class="card-body">
                        <p>Enter your username to receive a password reset link.</p>
                        <form id="forgotPasswordForm">
                            <div class="form-group">
                                <label>Username</label>
                                <input type="text" class="form-control" id="username" required>
                            </div>
                            <button type="submit" class="btn btn-primary">Request Reset Link</button>
                            <a href="/login" class="btn btn-secondary">Back to Login</a>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="/assets/vendors/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $('#forgotPasswordForm').on('submit', async function(e) {
            e.preventDefault();
            
            const response = await fetch('/forgot-password', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ username: $('#username').val() })
            });

            const result = await response.json();

            if (response.ok) {
                Swal.fire({
                    icon: 'success',
                    title: 'Reset Link Generated',
                    html: `<p>${result.message}</p><p><a href="${result.resetLink}">Reset Password</a></p>`
                });
            } else {
                Swal.fire('Error', result.error, 'error');
            }
        });
    </script>
</body>
</html>