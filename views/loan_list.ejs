<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width initial-scale=1.0">
    <title>Loans Management</title>
    <link href="./assets/vendors/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="./assets/vendors/font-awesome/css/font-awesome.min.css" rel="stylesheet" />
    <link href="./assets/vendors/themify-icons/css/themify-icons.css" rel="stylesheet" />
    <link href="./assets/vendors/DataTables/datatables.min.css" rel="stylesheet" />
    <link href="assets/css/main.min.css" rel="stylesheet" />
    <style>
        /* Compact DataTable */
        #loansTable {
            font-size: 12px;
        }       

        
        #loansTable thead th {
            padding: 4px 4px;
            font-size: 11px;
            white-space: nowrap;
            box-sizing: content-box;
            
        }
        
        #loansTable tbody td {
            padding: 6px 4px;
            vertical-align: middle;
        }
        
        /* Compact filters */
        .filter-section {
            background: #f8f9fa;
            padding: 10px;
            border-radius: 4px;
            margin-bottom: 10px;
        }
        
        .filter-section label {
            font-size: 11px;
            margin-bottom: 2px;
            font-weight: 600;
        }
        
        .filter-section .form-control-sm {
            height: 30px;
            font-size: 12px;
            padding: 4px 8px;
        }
        
        /* Compact buttons */
        .btn-xs {
            padding: 2px 6px;
            font-size: 11px;
            line-height: 1.5;
        }
        
        .btn-group .btn-sm {
            padding: 3px 6px;
            font-size: 11px;
        }
        
        /* Compact badges */
        .badge {
            font-size: 10px;
            padding: 3px 6px;
        }
        
        /* Page heading */
        .page-heading {
            padding: 10px 0;
        }
        
        .page-title {
            font-size: 20px;
            margin-bottom: 5px;
        }
        
        .breadcrumb {
            padding: 5px 0;
            margin-bottom: 0;
            font-size: 12px;
        }
        
        /* Compact ibox */
        .ibox-head {
            padding: 10px 15px;
        }
        
        .ibox-body {
            padding: 10px;
        }
        
        .ibox-title {
            font-size: 14px;
        }
        
        /* DataTables wrapper */
        .dataTables_wrapper .dataTables_length,
        .dataTables_wrapper .dataTables_filter,
        .dataTables_wrapper .dataTables_info,
        .dataTables_wrapper .dataTables_paginate {
            font-size: 12px;
        }
        
        .dataTables_wrapper .dataTables_length select {
            height: 28px;
            font-size: 12px;
        }
        
        /* Number columns right aligned */
        .text-right {
            text-align: right !important;
        }
        
        /* Status badges */
        .status-badge {
            padding: 3px 8px;
            border-radius: 3px;
            font-size: 10px;
            font-weight: 600;
            display: inline-block;
        }


    </style>
</head>

<body class="fixed-navbar">
    <div class="page-wrapper">
        <%- include('partials/header') %>
        <%- include('partials/sidebar') %>
        
        <div class="content-wrapper">
            <div class="page-heading">
                <h1 class="page-title">Loans Management</h1>
                <ol class="breadcrumb">
                    <li class="breadcrumb-item">
                        <a href="/"><i class="la la-home font-20"></i></a>
                    </li>
                    <li class="breadcrumb-item">Loans List</li>
                </ol>
            </div>
            
            <div class="page-content fade-in-up">
                <div class="ibox">
                    <div class="ibox-head">
                        <div class="ibox-title">All Loans</div>
                        <div class="ibox-tools">
                            <a href="/loan_application" class="btn btn-primary btn-sm">
                                <i class="fa fa-plus"></i> New Loan
                            </a>
                        </div>
                    </div>
                    
                    <div class="ibox-body">
                        <!-- Compact Filters -->
                        <div class="filter-section">
                            <div class="row">
                                <div class="col-md-2">
                                    <label>Member ID</label>
                                    <input type="text" id="memberId" placeholder="ID" class="form-control form-control-sm">
                                </div>
                                <div class="col-md-3">
                                    <label>Member Name</label>
                                    <input type="text" id="memberName" placeholder="Name" class="form-control form-control-sm">
                                </div>
                                <div class="col-md-2">
                                    <label>Status</label>
                                    <select id="loanStatus" class="form-control form-control-sm">
                                        <option value="">All</option>
                                        <option value="Active">Active</option>
                                        <option value="Pending">Pending</option>
                                        <option value="Completed">Completed</option>
                                        <option value="Defaulted">Defaulted</option>
                                    </select>
                                </div>
                                <div class="col-md-2" style="padding-top: 19px;">
                                    <button id="filterBtn" class="btn btn-primary btn-sm btn-block">
                                        <i class="fa fa-filter"></i> Filter
                                    </button>
                                </div>
                                <div class="col-md-2" style="padding-top: 19px;">
                                    <button id="clearBtn" class="btn btn-secondary btn-sm btn-block">
                                        <i class="fa fa-refresh"></i> Clear
                                    </button>
                                </div>
                            </div>
                        </div>

                        <!-- Compact DataTable -->
                        <div>
                        <table id="loansTable" class="table table-striped table-bordered table-hover" cellspacing="0" width="100%">                            
                                <thead>
                                    <tr>
                                        <th style="width:40pxpx; font-size: 11px;">ID</th>
                                        <th style="width:40pxpx; font-size: 11px;">M.ID</th>
                                        <th style="width:120px; font-size: 11px;"> Name</th>
                                        <th class="text-right" style="width:40px; font-size: 11px;">Amount</th>
                                        <th class="text-right" style="font-size: 11px";>Rate</th>
                                        <th style="font-size: 12px">Term</th>
                                        <th class="text-right" style="font-size: 11px;">Monthly</th>
                                        <th class="text-right" style="font-size: 11px;">Balance</th>
                                        <th class="text-right" style="font-size: 11px;">Interest</th>
                                        <th class="text-right" style="font-size: 11px;">Disbursed</th>
                                        <th class="text-right" style="font-size: 11px;">Status</th>
                                        <th style="font-size: 11px;">Actions</th>
                                    </tr>
                                </thead>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            
            <footer class="page-footer">
                <div class="font-13">2025 © <b>Fincas</b> - All rights reserved.</div>
            </footer>
        </div>
    </div>

    <script src="./assets/vendors/jquery/dist/jquery.min.js"></script>
    <script src="./assets/vendors/popper.js/dist/umd/popper.min.js"></script>
    <script src="./assets/vendors/bootstrap/dist/js/bootstrap.min.js"></script>
    <script src="./assets/vendors/metisMenu/dist/metisMenu.min.js"></script>
    <script src="./assets/vendors/jquery-slimscroll/jquery.slimscroll.min.js"></script>
    <script src="./assets/vendors/DataTables/datatables.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="assets/js/app.min.js"></script>

    <script>
$(document).ready(function() {
    var table = $('#loansTable').DataTable({
        processing: true,
        serverSide: true,
        ajax: {
            url: '/loans/list',
            type: 'POST',
            data: function(d) {
                d.memberId = $('#memberId').val();
                d.memberName = $('#memberName').val();
                d.loanStatus = $('#loanStatus').val();
            }
        },
        columns: [
            { 
                data: 'loan_id',
                width: '40px'
            },
            { 
                data: 'member_id',
                width: '40px'
            },
            { 
                data: 'member_name',
                width: '120px'
            },
            { 
                data: 'loan_amount',
                className: 'text-right',
                width: '80px',
                render: function(data) {
                    return parseFloat(data).toLocaleString('en-UG', {maximumFractionDigits: 0});
                }
            },
            { 
                data: 'interest_rate',
                className: 'text-right',
                width: '50px',
                render: function(data) {
                    return parseFloat(data).toFixed(1) + '%';
                }
            },
            { 
                data: 'loan_term_months',
                width: '40px',
                className: 'text-center',
                render: function(data) {
                    return data + 'm';
                }
            },
            { 
                data: 'monthly_payment',
                className: 'text-right',
                width: '80px',
                render: function(data) {
                    return parseFloat(data).toLocaleString('en-UG', {maximumFractionDigits: 0});
                }
            },
            { 
                data: 'balance',
                className: 'text-right',
                width: '80px',
                render: function(data) {
                    const val = parseFloat(data);
                    const formatted = val.toLocaleString('en-UG', {maximumFractionDigits: 0});
                    return val > 0 ? `<span class="text-danger">${formatted}</span>` : formatted;
                }
            },
            { 
                data: 'accumulated_interest',
                className: 'text-right',
                width: '80px',
                render: function(data) {
                    return parseFloat(data).toLocaleString('en-UG', {maximumFractionDigits: 0});
                }
            },
            { 
                data: 'disbursement_date',
                width: '80px',
                render: function(data) {
                    return new Date(data).toLocaleDateString('en-GB', {
                        day: '2-digit',
                        month: 'short',
                        year: '2-digit'
                    });
                }
            },
            { 
                data: 'status',
                width: '70px',
                render: function(data) {
                    const badges = {
                        'Active': 'success',
                        'Completed': 'primary',
                        'Defaulted': 'danger',
                        'Pending': 'warning'
                    };
                    const color = badges[data] || 'secondary';
                    return `<span class="badge badge-${color}">${data}</span>`;
                }
            },
            {
                data: null,
                orderable: false,
                width: '90px',
                render: function(data, type, row) {
                    return `
                        <div class="btn-group btn-group-sm" role="group">
                            <a href="/Loan_statement?loan_id=${row.loan_id}" 
                               class="btn btn-info btn-sm" 
                               title="Statement">
                                <i class="fa fa-file-text"></i>
                            </a>
                            <a href="/loan_repayment?loan_id=${row.loan_id}" 
                               class="btn btn-success btn-sm" 
                               title="Payment">
                                <i class="fa fa-money"></i>
                            </a>
                            <button class="btn btn-primary btn-sm view-interest-btn" 
                                    data-loan-id="${row.loan_id}"
                                    data-member-name="${row.member_name}"
                                    title="Interest">
                                <i class="fa fa-line-chart"></i>
                            </button>
                        </div>
                    `;
                }
            }
        ],
        order: [[0, 'desc']],
        pageLength: 25,
        lengthMenu: [[10, 25, 50, 100], [10, 25, 50, 100]],
        scrollX: true,
        autoWidth: false,
        dom: '<"row"<"col-sm-6"l><"col-sm-6"f>>rt<"row"<"col-sm-6"i><"col-sm-6"p>>'
    });

    $('#filterBtn').on('click', function() {
        table.ajax.reload();
    });

    $('#clearBtn').on('click', function() {
        $('#memberId').val('');
        $('#memberName').val('');
        $('#loanStatus').val('');
        table.ajax.reload();
    });

    $(document).on('click', '.view-interest-btn', function() {
        const loanId = $(this).data('loan-id');
        const memberName = $(this).data('member-name');
        viewInterestHistory(loanId, memberName);
    });
});

function viewInterestHistory(loanId, memberName) {
    Swal.fire({
        title: 'Loading...',
        allowOutsideClick: false,
        didOpen: () => { Swal.showLoading(); }
    });

    fetch(`/loans/${loanId}/interest-history?limit=90`)
        .then(response => response.json())
        .then(data => {
            displayInterestHistoryModal(loanId, memberName, data.history);
        })
        .catch(error => {
            console.error('Error:', error);
            Swal.fire({
                icon: 'error',
                title: 'Error',
                text: 'Failed to load interest history'
            });
        });
}

function displayInterestHistoryModal(loanId, memberName, history) {
    if (!history || history.length === 0) {
        Swal.fire({
            icon: 'info',
            title: 'No Interest History',
            text: 'No daily interest calculations found.'
        });
        return;
    }

    const totalInterest = history.reduce((sum, r) => sum + parseFloat(r.daily_interest_amount), 0);
    const avgBalance = history.reduce((sum, r) => sum + parseFloat(r.outstanding_balance), 0) / history.length;

    let tableHtml = `
        <div style="max-height: 450px; overflow-y: auto; font-size: 13px;">
            <div class="mb-2 p-2 bg-light rounded">
                <strong>Loan #${loanId}</strong> - ${memberName}
                <div class="row text-center mt-2">
                    <div class="col-4">
                        <small><strong>Days</strong></small><br>
                        <span class="badge badge-primary">${history.length}</span>
                    </div>
                    <div class="col-4">
                        <small><strong>Total Interest</strong></small><br>
                        <span class="badge badge-success">${totalInterest.toLocaleString('en-UG', {maximumFractionDigits: 0})}</span>
                    </div>
                    <div class="col-4">
                        <small><strong>Avg Balance</strong></small><br>
                        <span class="badge badge-info">${avgBalance.toLocaleString('en-UG', {maximumFractionDigits: 0})}</span>
                    </div>
                </div>
            </div>
            
            <table class="table table-sm table-striped table-bordered" style="font-size: 11px;">
                <thead class="thead-dark">
                    <tr>
                        <th>Date</th>
                        <th class="text-right">Balance</th>
                        <th class="text-right">Interest</th>
                        <th class="text-right">Rate</th>
                    </tr>
                </thead>
                <tbody>
    `;

    history.forEach(record => {
        const date = new Date(record.calculation_date).toLocaleDateString('en-GB', {
            day: '2-digit',
            month: 'short'
        });
        const balance = parseFloat(record.outstanding_balance).toLocaleString('en-UG', {maximumFractionDigits: 0});
        const interest = parseFloat(record.daily_interest_amount).toLocaleString('en-UG', {minimumFractionDigits: 2});
        const rate = parseFloat(record.annual_interest_rate).toFixed(1);

        tableHtml += `
            <tr>
                <td>${date}</td>
                <td class="text-right">${balance}</td>
                <td class="text-right">${interest}</td>
                <td class="text-right">${rate}%</td>
            </tr>
        `;
    });

    tableHtml += `
                </tbody>
            </table>
        </div>
        <div class="mt-2 text-center">
            <button onclick="exportInterestHistory(${loanId})" class="btn btn-sm btn-success">
                <i class="fa fa-download"></i> Export CSV
            </button>
            <button onclick="viewFullInterestHistory(${loanId})" class="btn btn-sm btn-primary">
                <i class="fa fa-expand"></i> View All
            </button>
        </div>
    `;

    Swal.fire({
        title: 'Interest History',
        html: tableHtml,
        width: '700px',
        showConfirmButton: true,
        confirmButtonText: 'Close'
    });
}

function viewFullInterestHistory(loanId) {
    window.open(`/loans/${loanId}/interest-full`, '_blank');
}

function exportInterestHistory(loanId) {
    window.location.href = `/loans/${loanId}/interest-export`;
}
    </script>
</body>
</html>