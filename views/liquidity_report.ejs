<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Liquidity Report</title>
    <link href="./assets/vendors/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="./assets/vendors/font-awesome/css/font-awesome.min.css" rel="stylesheet" />
    <link href="./assets/vendors/DataTables/datatables.min.css" rel="stylesheet" />
    <link href="assets/css/main.min.css" rel="stylesheet" />
    <style>
        .category-badge { padding:3px 8px; border-radius:3px; font-size:11px; font-weight:600; color:#fff; }
        .cat-bank        { background:#17a2b8; }
        .cat-unit        { background:#28a745; }
        .cat-mobile      { background:#ffc107; color:#333; }
        .cat-cash        { background:#dc3545; }
        .cat-other       { background:#6f42c1; }
        .summary-card    { border-left:4px solid; padding:10px 14px; margin-bottom:8px; background:#fff; border-radius:4px; box-shadow:0 1px 3px rgba(0,0,0,.08); }
    </style>
</head>
<body class="fixed-navbar">
<div class="page-wrapper">
    <%- include('partials/header') %>
    <%- include('partials/sidebar') %>

    <div class="content-wrapper">
        <div class="page-heading">
            <h1 class="page-title">Liquidity Report</h1>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/"><i class="la la-home font-20"></i></a></li>
                <li class="breadcrumb-item">Liquidity Report</li>
            </ol>
        </div>

        <div class="page-content fade-in-up">

            <!-- Summary Cards + Pie -->
            <div class="row">
                <div class="col-lg-4">
                    <div class="ibox">
                        <div class="ibox-head"><div class="ibox-title">Fund Distribution</div></div>
                        <div class="ibox-body">
                            <canvas id="report_pie" style="height:200px;"></canvas>
                        </div>
                    </div>
                </div>
                <div class="col-lg-8">
                    <div class="ibox">
                        <div class="ibox-head">
                            <div class="ibox-title">Summary by Category</div>
                            <div class="ibox-tools">
                                <button class="btn btn-success btn-xs" data-toggle="modal" data-target="#addModal">
                                    <i class="fa fa-plus"></i> Add Entry
                                </button>
                            </div>
                        </div>
                        <div class="ibox-body">
                            <div class="row">
                                <% const catColors = {
                                    'Bank':'#17a2b8','Unit Trust':'#28a745',
                                    'Mobile Money':'#ffc107','Cash':'#dc3545','Other':'#6f42c1'
                                }; %>
                                <% summary.forEach(function(s) { %>
                                    <div class="col-md-4 col-sm-6">
                                        <div class="summary-card" style="border-color:<%= catColors[s.category] || '#6c757d' %>">
                                            <div style="font-size:11px;color:#888;font-weight:600;text-transform:uppercase;">
                                                <%= s.category %>
                                            </div>
                                            <div style="font-size:18px;font-weight:700;color:<%= catColors[s.category] || '#333' %>">
                                                UGX <%= parseFloat(s.total_amount).toLocaleString('en-UG',{maximumFractionDigits:0}) %>
                                            </div>
                                            <div style="font-size:11px;color:#aaa;"><%= s.account_count %> account(s)</div>
                                        </div>
                                    </div>
                                <% }); %>
                                <div class="col-12 mt-2">
                                    <div class="summary-card" style="border-color:#343a40">
                                        <div style="font-size:11px;color:#888;font-weight:600;text-transform:uppercase;">Grand Total</div>
                                        <div style="font-size:22px;font-weight:700;color:#343a40">
                                            UGX <%= parseFloat(grandTotal).toLocaleString('en-UG',{maximumFractionDigits:0}) %>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Detail Table -->
            <div class="ibox">
                <div class="ibox-head">
                    <div class="ibox-title">Fund Details</div>
                    <div class="ibox-tools">
                        <select id="dateFilter" class="form-control form-control-sm" style="width:160px;font-size:12px;">
                            <% dates.forEach(d => { %>
                                <option value="<%= d.date_val %>"><%= d.date_val %></option>
                            <% }); %>
                        </select>
                    </div>
                </div>
                <div class="ibox-body">
                    <table id="liquidityTable" class="table table-striped table-bordered table-sm" style="font-size:12px;width:100%">
                        <thead class="thead-dark">
                            <tr>
                                <th>Category</th>
                                <th>Institution</th>
                                <th>Account Ref</th>
                                <th class="text-right">Amount (UGX)</th>
                                <th>As At Date</th>
                                <th>Notes</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody id="liquidityTableBody">
                            <% records.forEach(function(r) { %>
                            <tr>
                                <td>
                                    <span class="category-badge cat-<%= r.category.toLowerCase().replace(' ','') %>">
                                        <%= r.category %>
                                    </span>
                                </td>
                                <td><%= r.institution || '—' %></td>
                                <td><%= r.account_ref || '—' %></td>
                                <td class="text-right font-weight-bold">
                                    <%= parseFloat(r.amount).toLocaleString('en-UG',{maximumFractionDigits:0}) %>
                                </td>
                                <td><%= r.formatted_date %></td>
                                <td><%= r.notes || '' %></td>
                                <td>
                                    <button class="btn btn-xs btn-warning edit-btn"
                                        data-id="<%= r.id %>"
                                        data-category="<%= r.category %>"
                                        data-institution="<%= r.institution %>"
                                        data-account_ref="<%= r.account_ref %>"
                                        data-amount="<%= r.amount %>"
                                        data-notes="<%= r.notes %>"
                                        data-date="<%= r.as_at_date %>">
                                        <i class="fa fa-edit"></i>
                                    </button>
                                    <button class="btn btn-xs btn-danger delete-btn" data-id="<%= r.id %>">
                                        <i class="fa fa-trash"></i>
                                    </button>
                                </td>
                            </tr>
                            <% }); %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div><!-- end page-content -->

        <footer class="page-footer">
            <div class="font-13">2025 © <b>Fincas</b></div>
        </footer>
    </div>
</div>

<!-- Add/Edit Modal -->
<div class="modal fade" id="addModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Add Liquidity Entry</h5>
                <button type="button" class="close" data-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="entry_id">
                <div class="form-group">
                    <label style="font-size:12px;font-weight:600;">Category *</label>
                    <select id="entry_category" class="form-control form-control-sm">
                        <option value="Bank">Bank</option>
                        <option value="Unit Trust">Unit Trust</option>
                        <option value="Mobile Money">Mobile Money</option>
                        <option value="Cash">Cash</option>
                        <option value="Other">Other</option>
                    </select>
                </div>
                <div class="form-group">
                    <label style="font-size:12px;font-weight:600;">Institution</label>
                    <input type="text" id="entry_institution" class="form-control form-control-sm" placeholder="e.g. Stanbic Bank">
                </div>
                <div class="form-group">
                    <label style="font-size:12px;font-weight:600;">Account Reference</label>
                    <input type="text" id="entry_account_ref" class="form-control form-control-sm" placeholder="Account number">
                </div>
                <div class="form-group">
                    <label style="font-size:12px;font-weight:600;">Amount (UGX) *</label>
                    <input type="number" id="entry_amount" class="form-control form-control-sm" placeholder="0" min="0">
                </div>
                <div class="form-group">
                    <label style="font-size:12px;font-weight:600;">As At Date *</label>
                    <input type="date" id="entry_date" class="form-control form-control-sm">
                </div>
                <div class="form-group">
                    <label style="font-size:12px;font-weight:600;">Notes</label>
                    <textarea id="entry_notes" class="form-control form-control-sm" rows="2"></textarea>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary btn-sm" data-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary btn-sm" id="saveEntryBtn">Save</button>
            </div>
        </div>
    </div>
</div>

<script src="./assets/vendors/jquery/dist/jquery.min.js"></script>
<script src="./assets/vendors/popper.js/dist/umd/popper.min.js"></script>
<script src="./assets/vendors/bootstrap/dist/js/bootstrap.min.js"></script>
<script src="./assets/vendors/metisMenu/dist/metisMenu.min.js"></script>
<script src="./assets/vendors/jquery-slimscroll/jquery.slimscroll.min.js"></script>
<script src="./assets/vendors/DataTables/datatables.min.js"></script>
<script src="./assets/vendors/chart.js/dist/Chart.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
<script src="assets/js/app.min.js"></script>
<script>
$(function() {

    // Init DataTable
    var dt = $('#liquidityTable').DataTable({
        pageLength: 25,
        order: [[0,'asc']],
        dom: '<"row"<"col-sm-6"l><"col-sm-6"f>>rt<"row"<"col-sm-6"i><"col-sm-6"p>>'
    });

    // Pie Chart
    var pieColors = ['rgba(23,162,184,.85)','rgba(40,167,69,.85)','rgba(255,193,7,.85)','rgba(220,53,69,.85)','rgba(111,66,193,.85)','rgba(253,126,20,.85)'];
    var summaryData = <%- JSON.stringify(summary) %>;
    var ctx = document.getElementById('report_pie').getContext('2d');
    new Chart(ctx, {
        type: 'pie',
        data: {
            labels: summaryData.map(s => s.category),
            datasets: [{
                data: summaryData.map(s => parseFloat(s.total_amount)),
                backgroundColor: pieColors.slice(0, summaryData.length),
                borderWidth: 1
            }]
        },
        options: {
            responsive: true, maintainAspectRatio: false,
            tooltips: {
                callbacks: {
                    label: (item, data) => data.labels[item.index] + ': UGX ' +
                        data.datasets[0].data[item.index].toLocaleString('en-UG',{maximumFractionDigits:0})
                }
            }
        }
    });

    // Set today as default date in modal
    $('#entry_date').val(new Date().toISOString().split('T')[0]);

    // Edit button
    $(document).on('click', '.edit-btn', function() {
        var d = $(this).data();
        $('#modalTitle').text('Edit Entry');
        $('#entry_id').val(d.id);
        $('#entry_category').val(d.category);
        $('#entry_institution').val(d.institution !== 'undefined' ? d.institution : '');
        $('#entry_account_ref').val(d.account_ref !== 'undefined' ? d.account_ref : '');
        $('#entry_amount').val(d.amount);
        $('#entry_notes').val(d.notes !== 'undefined' ? d.notes : '');
        $('#entry_date').val(d.date ? d.date.split('T')[0] : '');
        $('#addModal').modal('show');
    });

    // Reset modal on open
    $('#addModal').on('show.bs.modal', function(e) {
        if (!$(e.relatedTarget).length) return; // opened by edit, skip reset
        $('#modalTitle').text('Add Entry');
        $('#entry_id').val('');
        $('#entry_institution, #entry_account_ref, #entry_notes').val('');
        $('#entry_amount').val('');
        $('#entry_category').val('Bank');
        $('#entry_date').val(new Date().toISOString().split('T')[0]);
    });

    // Save entry
    $('#saveEntryBtn').on('click', function() {
        var payload = {
            id:           $('#entry_id').val(),
            category:     $('#entry_category').val(),
            institution:  $('#entry_institution').val(),
            account_ref:  $('#entry_account_ref').val(),
            amount:       $('#entry_amount').val(),
            notes:        $('#entry_notes').val(),
            as_at_date:   $('#entry_date').val()
        };

        if (!payload.category || !payload.amount || !payload.as_at_date) {
            Swal.fire('Validation', 'Category, amount and date are required.', 'warning');
            return;
        }

        $.post('/liquidity/save', payload)
            .done(function() {
                Swal.fire({ icon:'success', title:'Saved', timer:1200, showConfirmButton:false })
                    .then(() => location.reload());
            })
            .fail(function() {
                Swal.fire('Error', 'Failed to save entry.', 'error');
            });
    });

    // Delete entry
    $(document).on('click', '.delete-btn', function() {
        var id = $(this).data('id');
        Swal.fire({
            title: 'Delete this entry?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#dc3545',
            confirmButtonText: 'Delete'
        }).then(result => {
            if (result.isConfirmed) {
                $.post('/liquidity/delete/' + id)
                    .done(() => Swal.fire({ icon:'success', title:'Deleted', timer:1000,
                        showConfirmButton:false }).then(() => location.reload()))
                    .fail(() => Swal.fire('Error','Failed to delete.','error'));
            }
        });
    });

    // Date filter
    $('#dateFilter').on('change', function() {
        $.post('/liquidity/filter', { as_at_date: $(this).val() })
            .done(function(data) {
                dt.clear();
                data.records.forEach(function(r) {
                    dt.row.add([
                        `<span class="category-badge cat-${r.category.toLowerCase().replace(' ','')}">${r.category}</span>`,
                        r.institution || '—',
                        r.account_ref || '—',
                        parseFloat(r.amount).toLocaleString('en-UG',{maximumFractionDigits:0}),
                        r.formatted_date,
                        r.notes || '',
                        `<button class="btn btn-xs btn-warning edit-btn" data-id="${r.id}"
                            data-category="${r.category}" data-institution="${r.institution}"
                            data-account_ref="${r.account_ref}" data-amount="${r.amount}"
                            data-notes="${r.notes}" data-date="${r.as_at_date}">
                            <i class="fa fa-edit"></i></button>
                         <button class="btn btn-xs btn-danger delete-btn" data-id="${r.id}">
                            <i class="fa fa-trash"></i></button>`
                    ]);
                });
                dt.draw();
            });
    });
});
</script>
</body>
</html>