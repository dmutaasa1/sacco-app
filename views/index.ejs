<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard - SACCO Management System</title>
    <link href="./assets/vendors/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="./assets/vendors/font-awesome/css/font-awesome.min.css" rel="stylesheet" />
    <link href="./assets/vendors/themify-icons/css/themify-icons.css" rel="stylesheet" />
    <link href="assets/css/main.min.css" rel="stylesheet" />

    <style>
        /* ════════════════════════════════════════
           STAT CARDS  — compact, 2×2 → 4×1
        ════════════════════════════════════════ */
        .stats-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 8px;
            margin-bottom: 12px;
        }
        @media (min-width: 992px) {
            .stats-grid { grid-template-columns: repeat(4,1fr); gap: 10px; }
        }

        .widget-stat { margin-bottom:0 !important; border-radius:6px; overflow:hidden; }
        .widget-stat .ibox-body {
            padding: 9px 11px;
            position: relative;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
            min-height: 78px;
        }
        .widget-stat-icon {
            position:absolute; right:8px; top:6px;
            font-size:2.4rem; opacity:.18;
        }
        .widget-stat h2 {
            font-size: clamp(.82rem,2vw,1.15rem);
            font-weight:700; margin:2px 0 0;
            word-break:break-all; line-height:1.15;
            position:relative; z-index:2;
        }
        .widget-stat-title {
            font-size:.58rem; font-weight:700;
            text-transform:uppercase; letter-spacing:.6px;
            opacity:.82; position:relative; z-index:2;
        }
        .widget-stat-footer {
            font-size:.62rem; opacity:.78;
            border-top:1px solid rgba(255,255,255,.18);
            padding-top:4px; margin-top:5px;
        }

        /* ════════════════════════════════════════
           TWO-COLUMN LAYOUT  big | small
        ════════════════════════════════════════ */
        .dash-cols {
            display:flex; flex-direction:column; gap:10px;
        }
        @media (min-width:992px) {
            .dash-cols { flex-direction:row; align-items:flex-start; }
            .dash-col-main { flex:0 0 62%; min-width:0; }
            .dash-col-side { flex:0 0 calc(38% - 10px); min-width:0; }
        }
        .dash-col-main, .dash-col-side {
            display:flex; flex-direction:column; gap:10px;
        }

        /* ── Shared card styles ── */
        .ibox { margin-bottom:0 !important; border-radius:6px; overflow:hidden; }
        .ibox-head {
            display:flex; align-items:center; justify-content:space-between;
            padding:8px 12px; border-bottom:1px solid #eaeef2;
        }
        .ibox-title {
            font-size:.7rem; font-weight:700;
            text-transform:uppercase; letter-spacing:.5px; color:#555;
        }
        .ibox-body { padding:11px 12px; }

        /* ════════════════════════════════════════
           CHART TABS — compact switcher
        ════════════════════════════════════════ */
        .chart-tab-bar {
            display:flex; gap:4px; margin-bottom:10px;
        }
        .chart-tab-btn {
            font-size:.65rem; font-weight:600;
            padding:3px 10px; border-radius:20px;
            border:1px solid #dee2e6; background:#f8f9fa;
            color:#666; cursor:pointer; transition:all .15s;
            white-space:nowrap;
        }
        .chart-tab-btn.active {
            background:#007bff; border-color:#007bff; color:#fff;
        }
        .chart-tab-btn:hover:not(.active) {
            background:#e9ecef; color:#333;
        }

        /* ── Chart wrappers ── */
        .chart-wrap-bar   { position:relative; height:200px; width:100%; }
        .chart-wrap-donut { position:relative; height:110px; width:100%; flex-shrink:0; }
        .chart-wrap-pie   { position:relative; height:110px; width:100%; flex-shrink:0; }
        @media (max-width:576px) {
            .chart-wrap-bar   { height:165px; }
            .chart-wrap-donut { height:95px; }
            .chart-wrap-pie   { height:95px; }
        }

        /* ── Inline chart+legend pairs ── */
        .split-row {
            display:flex; align-items:center; gap:10px;
        }
        .split-row .split-legend { flex:1; min-width:0; }
        @media (max-width:380px) {
            .split-row { flex-direction:column; }
            .split-row .chart-wrap-donut,
            .split-row .chart-wrap-pie { flex:none; width:100%; }
        }

        /* ── Income legend rows ── */
        .inc-row {
            display:flex; align-items:center; gap:4px;
            padding:5px 0; border-bottom:1px solid #f2f2f2; font-size:.7rem;
        }
        .inc-row:last-child { border-bottom:none; }
        .inc-dot  { width:6px; height:6px; border-radius:50%; flex-shrink:0; }
        .inc-name { flex:1; color:#555; }
        .inc-pct  { font-size:.63rem; color:#aaa; }
        .inc-val  { font-weight:600; font-size:.68rem; text-align:right; white-space:nowrap; }

        /* ── Liquidity ── */
        .liq-dot { display:inline-block; width:6px; height:6px; border-radius:50%; margin-right:4px; vertical-align:middle; flex-shrink:0; }
        .liq-leg-row { font-size:.67rem; margin-bottom:4px; display:flex; align-items:center; color:#555; }
        .liq-leg-row .pct { margin-left:auto; font-size:.62rem; color:#aaa; font-weight:600; }

        #liquidity_list { list-style:none; padding:0; margin:6px 0 0; }
        #liquidity_list li {
            display:flex; align-items:center; gap:4px;
            font-size:.68rem; padding:4px 0;
            border-bottom:1px solid #f2f2f2; color:#555;
        }
        #liquidity_list li:last-child { border-bottom:none; }
        #liquidity_list .liq-val { margin-left:auto; font-weight:600; color:#28a745; }

        .liq-total-bar {
            display:flex; justify-content:space-between; align-items:center;
            padding-top:6px; margin-top:5px;
            border-top:1px solid #eaeef2; font-size:.7rem;
        }
        .liq-total-bar strong { color:#333; }
        .liq-total-bar span   { font-weight:700; color:#007bff; }

        /* ── Loan stat rows ── */
        .loan-row {
            display:flex; align-items:center; gap:8px;
            padding:6px 0; border-bottom:1px solid #f2f2f2;
        }
        .loan-row:last-of-type { border-bottom:none; }
        .loan-ico {
            width:28px; height:28px; border-radius:6px;
            display:flex; align-items:center; justify-content:center;
            font-size:.75rem; flex-shrink:0;
        }
        .loan-val { font-size:.95rem; font-weight:700; line-height:1; }
        .loan-lbl { font-size:.62rem; color:#999; margin-top:1px; }

        /* ── Borrowers ── */
        .borrow-row {
            display:flex; align-items:center; gap:8px;
            padding:6px 0; border-bottom:1px solid #f2f2f2;
        }
        .borrow-row:last-child { border-bottom:none; }
        .borrow-av {
            width:28px; height:28px; border-radius:50%;
            display:flex; align-items:center; justify-content:center;
            font-weight:700; font-size:11px; color:#fff; flex-shrink:0;
        }
        .borrow-name   { font-size:.73rem; font-weight:600; line-height:1.2; }
        .borrow-name a { color:#333; text-decoration:none; }
        .borrow-name a:hover { color:#007bff; }
        .borrow-loans  { font-size:.61rem; color:#aaa; }
        .borrow-amt    { margin-left:auto; font-size:.68rem; font-weight:600; color:#28a745; white-space:nowrap; text-align:right; }

        /* ── Transactions table ── */
        .txn-wrap { overflow-x:auto; -webkit-overflow-scrolling:touch; }
        .txn-table { width:100%; border-collapse:collapse; }
        .txn-table th {
            font-size:.6rem; font-weight:700; text-transform:uppercase;
            letter-spacing:.4px; color:#aaa; padding:6px 9px;
            border-bottom:2px solid #eaeef2; background:#fafbfc; white-space:nowrap;
        }
        .txn-table td {
            font-size:.72rem; padding:6px 9px;
            border-bottom:1px solid #f0f4f8; color:#444; vertical-align:middle;
        }
        .txn-table tr:last-child td { border-bottom:none; }
        .txn-table tr:hover td { background:#fafbfc; }
        .txn-table a { color:#007bff; text-decoration:none; }
        .txn-table a:hover { text-decoration:underline; }
        .txn-badge {
            display:inline-block; font-size:.6rem; font-weight:600;
            padding:2px 6px; border-radius:3px; white-space:nowrap;
        }
        .txn-badge-cr { background:rgba(40,167,69,.11); color:#28a745; }
        .txn-badge-dr { background:rgba(255,193,7,.15); color:#856404; }
        .amt-cr { color:#28a745; font-weight:600; white-space:nowrap; }
        .amt-dr { color:#dc3545; font-weight:600; white-space:nowrap; }
        @media (max-width:600px) {
            .txn-table .col-id,
            .txn-table .col-type { display:none; }
        }
        @media (max-width:380px) { .txn-table .col-date { display:none; } }
    </style>
</head>

<body class="fixed-navbar">
<div class="page-wrapper">
    <%- include('partials/header') %>
    <%- include('partials/sidebar') %>

    <div class="content-wrapper">

        <div class="page-heading">
            <h1 class="page-title">Dashboard</h1>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/"><i class="la la-home font-20"></i></a></li>
                <li class="breadcrumb-item">Home</li>
            </ol>
        </div>

        <div class="page-content fade-in-up">

            <!-- ══ STAT CARDS ════════════════════════════════════ -->
            <div class="stats-grid">

                <div class="ibox bg-success color-white widget-stat">
                    <div class="ibox-body">
                        <i class="ti-wallet widget-stat-icon"></i>
                        <div class="widget-stat-title">Total Savings</div>
                        <h2>UGX <%= parseFloat(memberSaving||0).toLocaleString('en-UG',{maximumFractionDigits:0}) %></h2>
                        <div class="widget-stat-footer">YTD: UGX <%= parseFloat(memberYTDSaving||0).toLocaleString('en-UG',{maximumFractionDigits:0}) %></div>
                    </div>
                </div>

                <div class="ibox bg-info color-white widget-stat">
                    <div class="ibox-body">
                        <i class="ti-bar-chart widget-stat-icon"></i>
                        <div class="widget-stat-title">Loans Disbursed</div>
                        <h2>UGX <%= parseFloat(totalLoans||0).toLocaleString('en-UG',{maximumFractionDigits:0}) %></h2>
                        <div class="widget-stat-footer">Outstanding: UGX <%= parseFloat(outstandingLoans||0).toLocaleString('en-UG',{maximumFractionDigits:0}) %></div>
                    </div>
                </div>

                <div class="ibox bg-warning color-white widget-stat">
                    <div class="ibox-body">
                        <i class="fa fa-money widget-stat-icon"></i>
                        <div class="widget-stat-title">Income (YTD)</div>
                        <h2>UGX <%= parseFloat(memberIncome||0).toLocaleString('en-UG',{maximumFractionDigits:0}) %></h2>
                        <div class="widget-stat-footer">All Time: UGX <%= parseFloat(memberAllIncome||0).toLocaleString('en-UG',{maximumFractionDigits:0}) %></div>
                    </div>
                </div>

                <div class="ibox bg-danger color-white widget-stat">
                    <div class="ibox-body">
                        <i class="ti-user widget-stat-icon"></i>
                        <div class="widget-stat-title">Active Members</div>
                        <h2><%= memberCount||0 %></h2>
                        <div class="widget-stat-footer">Joined YTD: <%= ytd_memberCount||0 %></div>
                    </div>
                </div>

            </div>

            <!-- ══ TWO-COLUMN BODY ═══════════════════════════════ -->
            <div class="dash-cols">

                <!-- ─── BIG COLUMN ─────────────────────────────── -->
                <div class="dash-col-main">

                    <!-- Financial Stats with chart type tabs -->
                    <div class="ibox">
                        <div class="ibox-head">
                            <div class="ibox-title"><i class="fa fa-bar-chart mr-1 text-primary"></i>Financial Statistics</div>
                            <small class="text-muted" style="font-size:.62rem;"><%= new Date().getFullYear() %></small>
                        </div>
                        <div class="ibox-body">
                            <div class="chart-tab-bar">
                                <button class="chart-tab-btn active" data-chart="bar">Bar</button>
                                <button class="chart-tab-btn" data-chart="line">Line</button>
                                <button class="chart-tab-btn" data-chart="savings">Savings</button>
                                <button class="chart-tab-btn" data-chart="loans">Loans</button>
                            </div>
                            <div class="chart-wrap-bar">
                                <canvas id="bar_chart"></canvas>
                            </div>
                        </div>
                    </div>

                    <!-- Recent Transactions -->
                    <div class="ibox">
                        <div class="ibox-head">
                            <div class="ibox-title"><i class="fa fa-exchange mr-1 text-success"></i>Recent Transactions</div>
                            <a href="/transaction_list" class="btn btn-primary btn-xs">View All</a>
                        </div>
                        <div class="ibox-body" style="padding:0;">
                            <div class="txn-wrap">
                                <table class="txn-table">
                                    <thead>
                                        <tr>
                                            <th class="col-id">#</th>
                                            <th>Member</th>
                                            <th>Amount</th>
                                            <th class="col-type">Type</th>
                                            <th class="col-date">Date</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        <% if (recentTransactions && recentTransactions.length > 0) { %>
                                            <% recentTransactions.forEach(function(txn) { %>
                                                <tr>
                                                    <td class="col-id" style="color:#ccc;font-size:.62rem;">#<%= txn.id %></td>
                                                    <td><a href="/members/<%= txn.member_id %>"><%= txn.member_name %></a></td>
                                                    <td>
                                                        <span class="<%= txn.Debit_Credit==='Credit'?'amt-cr':'amt-dr' %>">
                                                            <%= txn.Debit_Credit==='Credit'?'+':'-' %> UGX <%= parseFloat(txn.Amount).toLocaleString() %>
                                                        </span>
                                                    </td>
                                                    <td class="col-type">
                                                        <span class="txn-badge <%= txn.Debit_Credit==='Credit'?'txn-badge-cr':'txn-badge-dr' %>">
                                                            <%= txn.transaction_type %>
                                                        </span>
                                                    </td>
                                                    <td class="col-date" style="color:#bbb;white-space:nowrap;font-size:.65rem;"><%= txn.tran_date %></td>
                                                </tr>
                                            <% }); %>
                                        <% } else { %>
                                            <tr><td colspan="5" style="text-align:center;padding:16px;color:#bbb;font-size:.72rem;">No transactions found</td></tr>
                                        <% } %>
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                </div><!-- /dash-col-main -->

                <!-- ─── SMALL COLUMN ────────────────────────────── -->
                <div class="dash-col-side">

                    <!-- Income Analysis -->
                    <div class="ibox">
                        <div class="ibox-head">
                            <div class="ibox-title"><i class="fa fa-pie-chart mr-1 text-warning"></i>Income Analysis</div>
                        </div>
                        <div class="ibox-body">
                            <div class="split-row">
                                <div class="chart-wrap-donut" style="flex:0 0 100px;">
                                    <canvas id="doughnut_chart"></canvas>
                                </div>
                                <div class="split-legend">
                                    <div class="inc-row">
                                        <span class="inc-dot" style="background:#28a745;"></span>
                                        <span class="inc-name">Interest</span>
                                        <span class="inc-pct"><%= interestPercentage %>%</span>
                                        <span class="inc-val text-success">UGX <%= parseFloat(interestIncome||0).toLocaleString() %></span>
                                    </div>
                                    <div class="inc-row">
                                        <span class="inc-dot" style="background:#ffc107;"></span>
                                        <span class="inc-name">Penalties</span>
                                        <span class="inc-pct"><%= penaltyPercentage %>%</span>
                                        <span class="inc-val text-warning">UGX <%= parseFloat(penaltyIncome||0).toLocaleString() %></span>
                                    </div>
                                    <div class="inc-row">
                                        <span class="inc-dot" style="background:#17a2b8;"></span>
                                        <span class="inc-name">Fees</span>
                                        <span class="inc-pct"><%= feePercentage %>%</span>
                                        <span class="inc-val text-info">UGX <%= parseFloat(feeIncome||0).toLocaleString() %></span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Fund Liquidity -->
                    <div class="ibox">
                        <div class="ibox-head">
                            <div class="ibox-title"><i class="fa fa-tint mr-1 text-info"></i>Fund Liquidity</div>
                            <a href="/liquidity_report" class="btn btn-primary btn-xs"><i class="fa fa-external-link"></i> Report</a>
                        </div>
                        <div class="ibox-body">
                            <div class="split-row">
                                <div class="chart-wrap-pie" style="flex:0 0 100px;">
                                    <canvas id="liquidity_chart"></canvas>
                                </div>
                                <div class="split-legend" id="liquidity_legend">
                                    <small class="text-muted"><i class="fa fa-spinner fa-spin"></i> Loading…</small>
                                </div>
                            </div>
                            <ul id="liquidity_list"></ul>
                            <div class="liq-total-bar">
                                <strong>Total Funds</strong>
                                <span id="liquidity_total">—</span>
                            </div>
                        </div>
                    </div>

                    <!-- Loan Statistics -->
                    <div class="ibox">
                        <div class="ibox-head">
                            <div class="ibox-title"><i class="fa fa-credit-card mr-1 text-primary"></i>Loan Stats</div>
                        </div>
                        <div class="ibox-body">
                            <div class="loan-row">
                                <div class="loan-ico" style="background:rgba(0,123,255,.1);color:#007bff;"><i class="fa fa-check-circle"></i></div>
                                <div>
                                    <div class="loan-val text-primary"><%= loanStats.total_active_loans||0 %></div>
                                    <div class="loan-lbl">Active Loans</div>
                                </div>
                            </div>
                            <div class="loan-row">
                                <div class="loan-ico" style="background:rgba(220,53,69,.1);color:#dc3545;"><i class="fa fa-exclamation-circle"></i></div>
                                <div>
                                    <div class="loan-val text-danger"><%= loanStats.loans_with_overdue||0 %></div>
                                    <div class="loan-lbl">With Overdue Payments</div>
                                </div>
                            </div>
                            <div class="loan-row">
                                <div class="loan-ico" style="background:rgba(40,167,69,.1);color:#28a745;"><i class="fa fa-money"></i></div>
                                <div style="min-width:0;">
                                    <div class="loan-val text-success" style="font-size:.82rem;word-break:break-all;">UGX <%= parseFloat(loanStats.total_outstanding||0).toLocaleString() %></div>
                                    <div class="loan-lbl">Outstanding Balance</div>
                                </div>
                            </div>
                            <a href="/loan_list" class="btn btn-primary btn-block btn-sm" style="margin-top:8px;font-size:.72rem;">
                                <i class="fa fa-list"></i> View All Loans
                            </a>
                        </div>
                    </div>

                    <!-- Top Borrowers -->
                    <div class="ibox">
                        <div class="ibox-head">
                            <div class="ibox-title"><i class="fa fa-trophy mr-1 text-warning"></i>Top Borrowers</div>
                        </div>
                        <div class="ibox-body">
                            <% var avColors=['#007bff','#28a745','#ffc107','#dc3545','#6f42c1']; %>
                            <% if (topBorrowers && topBorrowers.length > 0) { %>
                                <% topBorrowers.forEach(function(b,i){ %>
                                    <div class="borrow-row">
                                        <div class="borrow-av" style="background:<%=avColors[i%5]%>;"><%=b.name.charAt(0).toUpperCase()%></div>
                                        <div style="min-width:0;">
                                            <div class="borrow-name"><a href="/members/<%=b.id%>"><%=b.name%></a></div>
                                            <div class="borrow-loans"><%=b.loan_count%> loan<%=b.loan_count!=1?'s':''%></div>
                                        </div>
                                        <div class="borrow-amt">UGX <%=parseFloat(b.total_borrowed).toLocaleString()%></div>
                                    </div>
                                <% }); %>
                            <% } else { %>
                                <p class="text-center text-muted" style="font-size:.73rem;padding:6px 0;">No borrowers yet</p>
                            <% } %>
                        </div>
                    </div>

                </div><!-- /dash-col-side -->

            </div><!-- /dash-cols -->

        </div><!-- /page-content -->

        <footer class="page-footer">
            <div class="font-13">2025 © <b>Fincas</b> - All rights reserved.</div>
            <a class="px-4" href="#" target="_blank">Contact Us</a>
            <div class="to-top"><i class="fa fa-angle-double-up"></i></div>
        </footer>
    </div>
</div>

<!-- Scripts -->
<script src="./assets/vendors/jquery/dist/jquery.min.js"></script>
<script src="./assets/vendors/popper.js/dist/umd/popper.min.js"></script>
<script src="./assets/vendors/bootstrap/dist/js/bootstrap.min.js"></script>
<script src="./assets/vendors/metisMenu/dist/metisMenu.min.js"></script>
<script src="./assets/vendors/jquery-slimscroll/jquery.slimscroll.min.js"></script>
<script src="./assets/vendors/chart.js/dist/Chart.min.js"></script>
<script src="assets/js/app.min.js"></script>

<script>
$(function () {
    'use strict';

    /* ── Raw data from server ── */
    var SAVINGS = <%- savingsData %>;
    var INCOME  = <%- incomeData %>;
    var LOANS   = <%- loansData %>;
    var LABELS  = ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];

    function ugx(n) {
        return parseFloat(n).toLocaleString('en-UG', { maximumFractionDigits:0 });
    }

    /* ── Shared chart options helpers ── */
    var GRID_COLOR   = 'rgba(0,0,0,.04)';
    var TOOLTIP_OPTS = {
        backgroundColor: 'rgba(30,30,40,.88)',
        titleFontSize: 11, bodyFontSize: 11,
        cornerRadius: 6, displayColors: true,
        callbacks: {
            label: function(item, data) {
                return ' ' + data.datasets[item.datasetIndex].label + ': UGX ' +
                       parseFloat(item.yLabel).toLocaleString('en-UG',{maximumFractionDigits:0});
            }
        }
    };

    var LEGEND_OPTS = {
        display: true, position: 'top',
        labels: { fontSize:10, boxWidth:9, padding:12, fontColor:'#666' }
    };

    var Y_AXIS_OPTS = [{
        gridLines: { color: GRID_COLOR, zeroLineColor:'rgba(0,0,0,.08)' },
        ticks: {
            beginAtZero:true, fontSize:10, fontColor:'#999',
            callback: function(v) {
                if (v >= 1e6) return (v/1e6).toFixed(1)+'M';
                if (v >= 1e3) return (v/1e3).toFixed(0)+'K';
                return v;
            }
        }
    }];

    var X_AXIS_OPTS = [{
        gridLines:{ display:false },
        ticks:{ fontSize:10, fontColor:'#999' }
    }];

    /* ── Chart datasets ── */
    function makeBarDatasets() {
        return [
            {
                label:'Savings',
                backgroundColor:'rgba(40,167,69,.75)',
                borderColor:'rgba(40,167,69,1)',
                borderWidth:0,
                borderRadius:3,
                data: SAVINGS
            },
            {
                label:'Income',
                backgroundColor:'rgba(255,193,7,.75)',
                borderColor:'rgba(255,193,7,1)',
                borderWidth:0,
                borderRadius:3,
                data: INCOME
            },
            {
                label:'Loans',
                backgroundColor:'rgba(23,162,184,.75)',
                borderColor:'rgba(23,162,184,1)',
                borderWidth:0,
                borderRadius:3,
                data: LOANS
            }
        ];
    }

    function makeLineDatasets() {
        return [
            {
                label:'Savings',
                borderColor:'rgba(40,167,69,1)',
                backgroundColor:'rgba(40,167,69,.08)',
                pointBackgroundColor:'rgba(40,167,69,1)',
                pointRadius:3, pointHoverRadius:5,
                borderWidth:2, fill:true,
                data: SAVINGS
            },
            {
                label:'Income',
                borderColor:'rgba(255,193,7,1)',
                backgroundColor:'rgba(255,193,7,.08)',
                pointBackgroundColor:'rgba(255,193,7,1)',
                pointRadius:3, pointHoverRadius:5,
                borderWidth:2, fill:true,
                data: INCOME
            },
            {
                label:'Loans',
                borderColor:'rgba(23,162,184,1)',
                backgroundColor:'rgba(23,162,184,.08)',
                pointBackgroundColor:'rgba(23,162,184,1)',
                pointRadius:3, pointHoverRadius:5,
                borderWidth:2, fill:true,
                data: LOANS
            }
        ];
    }

    /* ── Build / rebuild main chart ── */
    var mainChart = null;
    var activeTab = 'bar';

    function buildMainChart(type) {
        var ctx = document.getElementById('bar_chart');
        if (mainChart) { mainChart.destroy(); }

        var chartType = (type === 'line') ? 'line' : 'bar';
        var datasets;

        if (type === 'savings') {
            chartType = 'bar';
            datasets = [{
                label:'Savings',
                backgroundColor: SAVINGS.map(function(v,i){
                    return 'rgba(40,167,69,' + (0.4 + 0.05*i) + ')';
                }),
                borderColor:'rgba(40,167,69,1)',
                borderWidth:0, borderRadius:3,
                data: SAVINGS
            }];
        } else if (type === 'loans') {
            chartType = 'bar';
            datasets = [{
                label:'Loans',
                backgroundColor: LOANS.map(function(v,i){
                    return 'rgba(23,162,184,' + (0.4 + 0.05*i) + ')';
                }),
                borderColor:'rgba(23,162,184,1)',
                borderWidth:0, borderRadius:3,
                data: LOANS
            }];
        } else if (type === 'line') {
            datasets = makeLineDatasets();
        } else {
            datasets = makeBarDatasets();
        }

        mainChart = new Chart(ctx, {
            type: chartType,
            data: { labels: LABELS, datasets: datasets },
            options: {
                responsive:true, maintainAspectRatio:false,
                animation: { duration:350, easing:'easeInOutQuart' },
                legend: LEGEND_OPTS,
                scales: { xAxes: X_AXIS_OPTS, yAxes: Y_AXIS_OPTS },
                tooltips: TOOLTIP_OPTS
            }
        });
    }

    buildMainChart('bar');

    /* ── Tab switching ── */
    document.querySelectorAll('.chart-tab-btn').forEach(function(btn) {
        btn.addEventListener('click', function() {
            document.querySelectorAll('.chart-tab-btn').forEach(function(b){ b.classList.remove('active'); });
            btn.classList.add('active');
            activeTab = btn.getAttribute('data-chart');
            buildMainChart(activeTab);
        });
    });

    /* ── 2. Doughnut ── */
    new Chart(document.getElementById('doughnut_chart'), {
        type:'doughnut',
        data:{
            labels:['Loan Interest','Penalties','Fees'],
            datasets:[{
                data:[<%= interestIncome %>, <%= penaltyIncome %>, <%= feeIncome %>],
                backgroundColor:['rgba(40,167,69,.8)','rgba(255,193,7,.8)','rgba(23,162,184,.8)'],
                borderColor:['rgba(40,167,69,1)','rgba(255,193,7,1)','rgba(23,162,184,1)'],
                borderWidth:2
            }]
        },
        options:{
            responsive:true, maintainAspectRatio:false,
            cutoutPercentage:68, legend:{display:false},
            animation:{ animateRotate:true, duration:600 },
            tooltips:{
                backgroundColor:'rgba(30,30,40,.88)',
                cornerRadius:6, titleFontSize:10, bodyFontSize:10,
                callbacks:{
                    label:function(item,d){
                        return ' '+d.labels[item.index]+': UGX '+
                               parseFloat(d.datasets[0].data[item.index]).toLocaleString();
                    }
                }
            }
        }
    });

    /* ── 3. Liquidity Pie ── */
    var LIQ = [
        'rgba(23,162,184,.85)','rgba(40,167,69,.85)','rgba(255,193,7,.85)',
        'rgba(220,53,69,.85)','rgba(111,66,193,.85)','rgba(253,126,20,.85)',
        'rgba(32,201,151,.85)'
    ];
    var liqChart = null;

    fetch('/liquidity/summary')
        .then(function(r){ return r.json(); })
        .then(function(data){
            var cats   = data.categories || [];
            var total  = data.total || 0;
            var labels = cats.map(function(c){ return c.category; });
            var values = cats.map(function(c){ return parseFloat(c.total_amount); });
            var colors = LIQ.slice(0, labels.length);

            if (liqChart) liqChart.destroy();

            if (!values.length) {
                document.getElementById('liquidity_legend').innerHTML =
                    '<small class="text-muted">No data yet. <a href="/liquidity_report">Add funds</a></small>';
                document.getElementById('liquidity_total').textContent = 'UGX 0';
                return;
            }

            liqChart = new Chart(document.getElementById('liquidity_chart'), {
                type:'pie',
                data:{
                    labels:labels,
                    datasets:[{ data:values, backgroundColor:colors, borderColor:'#fff', borderWidth:2 }]
                },
                options:{
                    responsive:true, maintainAspectRatio:false,
                    animation:{ animateRotate:true, duration:600 },
                    legend:{display:false},
                    tooltips:{
                        backgroundColor:'rgba(30,30,40,.88)',
                        cornerRadius:6, titleFontSize:10, bodyFontSize:10,
                        callbacks:{
                            label:function(item,d){
                                var v=d.datasets[0].data[item.index];
                                var pct=total>0?((v/total)*100).toFixed(1):0;
                                return ' '+d.labels[item.index]+': UGX '+ugx(v)+' ('+pct+'%)';
                            }
                        }
                    }
                }
            });

            /* Legend beside pie */
            var leg='';
            cats.forEach(function(c,i){
                var pct=total>0?((parseFloat(c.total_amount)/total)*100).toFixed(1):0;
                leg+='<div class="liq-leg-row">'+
                     '<span class="liq-dot" style="background:'+LIQ[i]+'"></span>'+
                     '<span>'+c.category+'</span>'+
                     '<span class="pct">'+pct+'%</span></div>';
            });
            document.getElementById('liquidity_legend').innerHTML=leg;

            /* Detail list */
            var lst='';
            cats.forEach(function(c,i){
                lst+='<li><span class="liq-dot" style="background:'+LIQ[i]+'"></span>'+
                     '<span>'+c.category+'</span>'+
                     '<span class="liq-val">UGX '+ugx(c.total_amount)+'</span></li>';
            });
            document.getElementById('liquidity_list').innerHTML=lst||
                '<li style="justify-content:center;color:#bbb;">No entries. <a href="/liquidity_report">Add funds</a></li>';

            document.getElementById('liquidity_total').textContent='UGX '+ugx(total);
        })
        .catch(function(){
            document.getElementById('liquidity_legend').innerHTML=
                '<small class="text-danger"><i class="fa fa-exclamation-circle"></i> Failed to load</small>';
        });
});
</script>
</body>
</html>
