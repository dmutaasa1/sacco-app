<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <title>Dashboard - SACCO Management System</title>

    <link href="./assets/vendors/bootstrap/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="./assets/vendors/font-awesome/css/font-awesome.min.css" rel="stylesheet" />
    <link href="./assets/vendors/themify-icons/css/themify-icons.css" rel="stylesheet" />
    <link href="assets/css/main.min.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@300;400;500;600;700&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">

    <style>
        /* ── Design tokens ── */
        :root {
            --green:      #00b894;
            --green-dark: #00907a;
            --green-soft: rgba(0,184,148,.12);
            --blue:       #0984e3;
            --blue-soft:  rgba(9,132,227,.10);
            --amber:      #e17055;
            --amber-soft: rgba(225,112,85,.10);
            --red:        #d63031;
            --red-soft:   rgba(214,48,49,.10);
            --purple:     #6c5ce7;
            --purple-soft:rgba(108,92,231,.10);
            --ink:        #1a1f2e;
            --ink-2:      #4a5568;
            --ink-3:      #718096;
            --border:     #e8ecf0;
            --surface:    #ffffff;
            --bg:         #f4f6fa;
            --radius:     14px;
            --radius-sm:  8px;
            --shadow:     0 2px 16px rgba(26,31,46,.07);
            --shadow-md:  0 4px 24px rgba(26,31,46,.11);
        }

        * { box-sizing: border-box; }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg);
            color: var(--ink);
        }

        /* ── Page header ── */
        .page-heading h1 {
            font-family: 'DM Sans', sans-serif;
            font-weight: 700;
            font-size: 1.5rem;
            color: var(--ink);
            letter-spacing: -.3px;
        }

        /* ── STAT CARDS ── */
        .stats-grid {
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 12px;
            margin-bottom: 16px;
        }

        @media (max-width: 1100px) { .stats-grid { grid-template-columns: repeat(2, 1fr); } }
        @media (max-width: 520px)  { .stats-grid { grid-template-columns: 1fr 1fr; gap: 9px; } }

        .stat-card {
            background: var(--surface);
            border-radius: var(--radius);
            padding: 14px 14px 11px;
            box-shadow: var(--shadow);
            position: relative;
            overflow: hidden;
            border: 1px solid var(--border);
            transition: transform .2s, box-shadow .2s;
        }
        .stat-card:hover { transform: translateY(-2px); box-shadow: var(--shadow-md); }

        .stat-card__accent {
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 3px;
            border-radius: var(--radius) var(--radius) 0 0;
        }

        .stat-card__icon {
            width: 34px; height: 34px;
            border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            font-size: 15px;
            margin-bottom: 9px;
        }

        .stat-card__value {
            font-family: 'DM Mono', monospace;
            font-size: clamp(1rem, 2.5vw, 1.3rem);
            font-weight: 500;
            color: var(--ink);
            line-height: 1.1;
            margin-bottom: 4px;
            word-break: break-all;
        }

        .stat-card__label {
            font-size: .7rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .8px;
            color: var(--ink-3);
            margin-bottom: 10px;
        }

        .stat-card__footer {
            font-size: .72rem;
            color: var(--ink-3);
            padding-top: 10px;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            gap: 5px;
        }
        .stat-card__footer strong { color: var(--ink-2); }

        /* colour variants */
        .stat--green .stat-card__accent { background: var(--green); }
        .stat--green .stat-card__icon   { background: var(--green-soft); color: var(--green); }
        .stat--blue  .stat-card__accent { background: var(--blue); }
        .stat--blue  .stat-card__icon   { background: var(--blue-soft); color: var(--blue); }
        .stat--amber .stat-card__accent { background: var(--amber); }
        .stat--amber .stat-card__icon   { background: var(--amber-soft); color: var(--amber); }
        .stat--red   .stat-card__accent { background: var(--red); }
        .stat--red   .stat-card__icon   { background: var(--red-soft); color: var(--red); }

        /* ── CARDS (generic) ── */
        .card-panel {
            background: var(--surface);
            border-radius: var(--radius);
            box-shadow: var(--shadow);
            border: 1px solid var(--border);
            overflow: hidden;
            margin-bottom: 0;
        }

        .card-panel__head {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 11px 14px 10px;
            border-bottom: 1px solid var(--border);
        }

        .card-panel__title {
            font-size: .78rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .8px;
            color: var(--ink-2);
            display: flex;
            align-items: center;
            gap: 6px;
        }
        .card-panel__title i { font-size: .9rem; }

        .card-panel__body { padding: 13px 14px; }

        /* ── BTN ── */
        .btn-pill {
            border-radius: 50px;
            font-size: .72rem;
            font-weight: 600;
            padding: 5px 13px;
            letter-spacing: .3px;
            border: none;
        }
        .btn-pill-green  { background: var(--green-soft);  color: var(--green-dark); }
        .btn-pill-blue   { background: var(--blue-soft);   color: var(--blue); }
        .btn-pill-solid  { background: var(--green); color: #fff; }
        .btn-pill-solid:hover { background: var(--green-dark); color: #fff; }

        /* ── CHART WRAPPERS ── */
        .chart-wrap { position: relative; width: 100%; }
        .chart-wrap--bar    { height: 220px; }
        .chart-wrap--donut  { height: 120px; }
        .chart-wrap--pie    { height: 130px; }

        @media (max-width: 576px) {
            .chart-wrap--bar   { height: 180px; }
            .chart-wrap--donut { height: 110px; }
        }

        /* ── INCOME LEGEND ── */
        .income-legend { list-style: none; padding: 0; margin: 0; }
        .income-legend li {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 7px 0;
            border-bottom: 1px solid var(--border);
            font-size: .75rem;
            gap: 6px;
        }
        .income-legend li:last-child { border-bottom: none; }
        .income-legend__dot {
            width: 7px; height: 7px;
            border-radius: 50%;
            flex-shrink: 0;
        }
        .income-legend__name { flex: 1; color: var(--ink-2); font-weight: 500; }
        .income-legend__pct  { font-size: .68rem; color: var(--ink-3); margin-right: 5px; }
        .income-legend__val  { font-family: 'DM Mono', monospace; font-size: .72rem; font-weight: 500; color: var(--ink); }

        /* ── LOAN STAT ITEMS ── */
        .loan-stat-row {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
        }
        .loan-stat-row:last-child { border-bottom: none; }
        .loan-stat-row__ico {
            width: 36px; height: 36px;
            border-radius: 9px;
            display: flex; align-items: center; justify-content: center;
            font-size: 14px;
            flex-shrink: 0;
        }
        .loan-stat-row__val { font-family: 'DM Mono', monospace; font-size: 1.15rem; font-weight: 500; color: var(--ink); }
        .loan-stat-row__lbl { font-size: .72rem; color: var(--ink-3); }

        /* ── LIQUIDITY LEGEND ── */
        .liq-legend { list-style: none; padding: 0; margin: 0; }
        .liq-legend li {
            display: flex;
            align-items: center;
            gap: 7px;
            font-size: .75rem;
            margin-bottom: 7px;
            color: var(--ink-2);
        }
        .liq-dot {
            width: 9px; height: 9px;
            border-radius: 50%;
            flex-shrink: 0;
        }
        .liq-legend__pct { margin-left: auto; font-size: .7rem; color: var(--ink-3); font-weight: 600; }

        #liquidity_list {
            list-style: none;
            padding: 0; margin: 0;
        }
        #liquidity_list li {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: .75rem;
            padding: 7px 0;
            border-bottom: 1px solid var(--border);
            color: var(--ink-2);
        }
        #liquidity_list li:last-child { border-bottom: none; }
        #liquidity_list .liq-val {
            margin-left: auto;
            font-family: 'DM Mono', monospace;
            font-size: .73rem;
            color: var(--green-dark);
            font-weight: 500;
        }

        /* ── TOP BORROWERS ── */
        .borrower-row {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 10px 0;
            border-bottom: 1px solid var(--border);
        }
        .borrower-row:last-child { border-bottom: none; }
        .borrower-avatar {
            width: 36px; height: 36px;
            border-radius: 9px;
            background: var(--green-soft);
            color: var(--green-dark);
            font-weight: 700;
            font-size: 14px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
        }
        .borrower-name { font-size: .8rem; font-weight: 600; color: var(--ink); line-height: 1.2; }
        .borrower-name a { color: inherit; text-decoration: none; }
        .borrower-name a:hover { color: var(--green); }
        .borrower-loans { font-size: .68rem; color: var(--ink-3); margin-top: 1px; }
        .borrower-amount {
            margin-left: auto;
            font-family: 'DM Mono', monospace;
            font-size: .73rem;
            color: var(--green-dark);
            font-weight: 500;
            text-align: right;
        }

        /* ── TRANSACTIONS TABLE ── */
        .txn-table { width: 100%; border-collapse: collapse; }
        .txn-table th {
            font-size: .68rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: .6px;
            color: var(--ink-3);
            padding: 8px 10px;
            border-bottom: 2px solid var(--border);
            white-space: nowrap;
            background: var(--bg);
        }
        .txn-table td {
            font-size: .78rem;
            padding: 9px 10px;
            border-bottom: 1px solid var(--border);
            color: var(--ink-2);
            vertical-align: middle;
        }
        .txn-table tr:last-child td { border-bottom: none; }
        .txn-table tr:hover td { background: var(--bg); }
        .txn-table a { color: var(--blue); text-decoration: none; font-weight: 500; }
        .txn-table a:hover { text-decoration: underline; }

        .badge-type {
            display: inline-block;
            font-size: .64rem;
            font-weight: 600;
            padding: 2px 8px;
            border-radius: 50px;
            white-space: nowrap;
        }
        .badge-credit { background: var(--green-soft);  color: var(--green-dark); }
        .badge-debit  { background: var(--amber-soft);  color: var(--amber); }

        .amount-credit { color: var(--green-dark); font-family: 'DM Mono', monospace; font-size: .77rem; font-weight: 500; }
        .amount-debit  { color: var(--amber);       font-family: 'DM Mono', monospace; font-size: .77rem; font-weight: 500; }

        /* hide less critical columns on small screens */
        @media (max-width: 640px) {
            .txn-table .col-type,
            .txn-table .col-id { display: none; }
        }
        @media (max-width: 420px) {
            .txn-table .col-date { display: none; }
        }

        /* ── GRID LAYOUTS ── */
        .grid-8-4 {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 16px;
            margin-bottom: 16px;
            align-items: start;   /* ← prevents stretching to equal height */
        }
        .grid-8-4 .col-8 { grid-column: span 2; }
        .grid-8-4 .col-4 { grid-column: span 1; }

        .grid-4-4-4 {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 16px;
            margin-bottom: 16px;
            align-items: start;
        }

        @media (max-width: 992px) {
            .grid-8-4 { grid-template-columns: 1fr; }
            .grid-8-4 .col-8,
            .grid-8-4 .col-4 { grid-column: span 1; }
            .grid-4-4-4 { grid-template-columns: 1fr 1fr; }
        }
        @media (max-width: 600px) {
            .grid-4-4-4 { grid-template-columns: 1fr; }
        }

        /* ── LIQIDITY TOTAL BAR ── */
        .liq-total-bar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px 0 0;
            margin-top: 10px;
            border-top: 1px solid var(--border);
            font-size: .78rem;
        }
        .liq-total-bar strong { color: var(--ink); }
        .liq-total-bar span { font-family: 'DM Mono', monospace; font-size: .8rem; font-weight: 600; color: var(--green-dark); }

        /* ── SCROLL WRAPPER for table on mobile ── */
        .table-scroll { overflow-x: auto; -webkit-overflow-scrolling: touch; }

        /* ── FADE IN ── */
        .fade-up {
            opacity: 0;
            transform: translateY(18px);
            animation: fadeUp .45s ease forwards;
        }
        @keyframes fadeUp {
            to { opacity: 1; transform: translateY(0); }
        }
        .delay-1 { animation-delay: .05s; }
        .delay-2 { animation-delay: .10s; }
        .delay-3 { animation-delay: .15s; }
        .delay-4 { animation-delay: .20s; }
        .delay-5 { animation-delay: .25s; }
        .delay-6 { animation-delay: .30s; }
    </style>
</head>

<body class="fixed-navbar">
<div class="page-wrapper">
    <%- include('partials/header') %>
    <%- include('partials/sidebar') %>

    <div class="content-wrapper">

        <div class="page-heading">
            <h1 class="page-title">Dashboard</h1>
            <ol class="breadcrumb">
                <li class="breadcrumb-item"><a href="/"><i class="la la-home font-20"></i></a></li>
                <li class="breadcrumb-item">Home</li>
            </ol>
        </div>

        <div class="page-content">

            <!-- ══ STAT CARDS ══════════════════════════════════════════ -->
            <div class="stats-grid">

                <div class="stat-card stat--green fade-up delay-1">
                    <div class="stat-card__accent"></div>
                    <div class="stat-card__icon"><i class="ti-wallet"></i></div>
                    <div class="stat-card__label">Total Savings</div>
                    <div class="stat-card__value">UGX&nbsp;<%= parseFloat(memberSaving||0).toLocaleString('en-UG',{maximumFractionDigits:0}) %></div>
                    <div class="stat-card__footer">
                        <i class="fa fa-arrow-up" style="color:var(--green);font-size:.65rem;"></i>
                        YTD: <strong>UGX&nbsp;<%= parseFloat(memberYTDSaving||0).toLocaleString('en-UG',{maximumFractionDigits:0}) %></strong>
                    </div>
                </div>

                <div class="stat-card stat--blue fade-up delay-2">
                    <div class="stat-card__accent"></div>
                    <div class="stat-card__icon"><i class="ti-bar-chart"></i></div>
                    <div class="stat-card__label">Loans Disbursed</div>
                    <div class="stat-card__value">UGX&nbsp;<%= parseFloat(totalLoans||0).toLocaleString('en-UG',{maximumFractionDigits:0}) %></div>
                    <div class="stat-card__footer">
                        <i class="fa fa-minus-circle" style="color:var(--amber);font-size:.65rem;"></i>
                        Outstanding: <strong>UGX&nbsp;<%= parseFloat(outstandingLoans||0).toLocaleString('en-UG',{maximumFractionDigits:0}) %></strong>
                    </div>
                </div>

                <div class="stat-card stat--amber fade-up delay-3">
                    <div class="stat-card__accent"></div>
                    <div class="stat-card__icon"><i class="fa fa-money"></i></div>
                    <div class="stat-card__label">Income (YTD)</div>
                    <div class="stat-card__value">UGX&nbsp;<%= parseFloat(memberIncome||0).toLocaleString('en-UG',{maximumFractionDigits:0}) %></div>
                    <div class="stat-card__footer">
                        <i class="fa fa-history" style="font-size:.65rem;"></i>
                        All Time: <strong>UGX&nbsp;<%= parseFloat(memberAllIncome||0).toLocaleString('en-UG',{maximumFractionDigits:0}) %></strong>
                    </div>
                </div>

                <div class="stat-card stat--red fade-up delay-4">
                    <div class="stat-card__accent"></div>
                    <div class="stat-card__icon"><i class="ti-user"></i></div>
                    <div class="stat-card__label">Active Members</div>
                    <div class="stat-card__value"><%= memberCount||0 %></div>
                    <div class="stat-card__footer">
                        <i class="fa fa-user-plus" style="color:var(--green);font-size:.65rem;"></i>
                        Joined YTD: <strong><%= ytd_memberCount||0 %></strong>
                    </div>
                </div>

            </div>

            <!-- ══ ROW 1: Bar chart + Income doughnut ══════════════════ -->
            <div class="grid-8-4">

                <div class="col-8 card-panel fade-up delay-2">
                    <div class="card-panel__head">
                        <div class="card-panel__title">
                            <i class="fa fa-bar-chart text-primary"></i> Financial Statistics
                        </div>
                        <span style="font-size:.7rem; color:var(--ink-3);">Monthly · <%= new Date().getFullYear() %></span>
                    </div>
                    <div class="card-panel__body">
                        <div class="chart-wrap chart-wrap--bar">
                            <canvas id="bar_chart"></canvas>
                        </div>
                    </div>
                </div>

                <div class="col-4 card-panel fade-up delay-3">
                    <div class="card-panel__head">
                        <div class="card-panel__title">
                            <i class="fa fa-pie-chart text-warning"></i> Income Split
                        </div>
                    </div>
                    <div class="card-panel__body">
                        <div class="chart-wrap chart-wrap--donut" style="margin-bottom:10px;">
                            <canvas id="doughnut_chart"></canvas>
                        </div>
                        <ul class="income-legend">
                            <li>
                                <span class="income-legend__dot" style="background:var(--green);"></span>
                                <span class="income-legend__name">Interest</span>
                                <span class="income-legend__pct"><%= interestPercentage %>%</span>
                                <span class="income-legend__val">UGX&nbsp;<%= parseFloat(interestIncome||0).toLocaleString() %></span>
                            </li>
                            <li>
                                <span class="income-legend__dot" style="background:var(--amber);"></span>
                                <span class="income-legend__name">Penalties</span>
                                <span class="income-legend__pct"><%= penaltyPercentage %>%</span>
                                <span class="income-legend__val">UGX&nbsp;<%= parseFloat(penaltyIncome||0).toLocaleString() %></span>
                            </li>
                            <li>
                                <span class="income-legend__dot" style="background:var(--blue);"></span>
                                <span class="income-legend__name">Fees</span>
                                <span class="income-legend__pct"><%= feePercentage %>%</span>
                                <span class="income-legend__val">UGX&nbsp;<%= parseFloat(feeIncome||0).toLocaleString() %></span>
                            </li>
                        </ul>
                    </div>
                </div>

            </div>

            <!-- ══ ROW 2: Liquidity + Loan stats + Top borrowers ═══════ -->
            <div class="grid-4-4-4">

                <!-- Liquidity -->
                <div class="card-panel fade-up delay-3">
                    <div class="card-panel__head">
                        <div class="card-panel__title">
                            <i class="fa fa-tint text-info"></i> Fund Liquidity
                        </div>
                        <a href="/liquidity_report" class="btn-pill btn-pill-blue">
                            <i class="fa fa-external-link"></i> Report
                        </a>
                    </div>
                    <div class="card-panel__body">
                        <div class="chart-wrap chart-wrap--pie" style="margin-bottom:12px;">
                            <canvas id="liquidity_chart"></canvas>
                        </div>
                        <ul class="liq-legend" id="liquidity_legend">
                            <li><i class="fa fa-spinner fa-spin" style="color:var(--ink-3);"></i>&nbsp;Loading…</li>
                        </ul>
                        <ul id="liquidity_list"></ul>
                        <div class="liq-total-bar">
                            <strong>Total Funds</strong>
                            <span id="liquidity_total">—</span>
                        </div>
                    </div>
                </div>

                <!-- Loan stats -->
                <div class="card-panel fade-up delay-4">
                    <div class="card-panel__head">
                        <div class="card-panel__title">
                            <i class="fa fa-credit-card text-primary"></i> Loan Stats
                        </div>
                    </div>
                    <div class="card-panel__body">
                        <div class="loan-stat-row">
                            <div class="loan-stat-row__ico" style="background:var(--blue-soft);color:var(--blue);">
                                <i class="fa fa-check-circle"></i>
                            </div>
                            <div>
                                <div class="loan-stat-row__val"><%= loanStats.total_active_loans||0 %></div>
                                <div class="loan-stat-row__lbl">Active Loans</div>
                            </div>
                        </div>
                        <div class="loan-stat-row">
                            <div class="loan-stat-row__ico" style="background:var(--red-soft);color:var(--red);">
                                <i class="fa fa-exclamation-circle"></i>
                            </div>
                            <div>
                                <div class="loan-stat-row__val"><%= loanStats.loans_with_overdue||0 %></div>
                                <div class="loan-stat-row__lbl">With Overdue Payments</div>
                            </div>
                        </div>
                        <div class="loan-stat-row">
                            <div class="loan-stat-row__ico" style="background:var(--green-soft);color:var(--green);">
                                <i class="fa fa-money"></i>
                            </div>
                            <div>
                                <div class="loan-stat-row__val" style="font-size:.95rem;">UGX&nbsp;<%= parseFloat(loanStats.total_outstanding||0).toLocaleString() %></div>
                                <div class="loan-stat-row__lbl">Outstanding Balance</div>
                            </div>
                        </div>
                        <a href="/loan_list" class="btn-pill btn-pill-solid d-block text-center mt-3" style="padding:8px;">
                            <i class="fa fa-list"></i>&nbsp; View All Loans
                        </a>
                    </div>
                </div>

                <!-- Top borrowers -->
                <div class="card-panel fade-up delay-5">
                    <div class="card-panel__head">
                        <div class="card-panel__title">
                            <i class="fa fa-trophy text-warning"></i> Top Borrowers
                        </div>
                    </div>
                    <div class="card-panel__body">
                        <% if (topBorrowers && topBorrowers.length > 0) { %>
                            <% topBorrowers.forEach(function(b, i) { %>
                                <div class="borrower-row">
                                    <div class="borrower-avatar" style="background:<% var colors=['var(--green-soft)','var(--blue-soft)','var(--amber-soft)','var(--red-soft)','var(--purple-soft)']; %><%=colors[i%5]%>; color:<% var tc=['var(--green-dark)','var(--blue)','var(--amber)','var(--red)','var(--purple)']; %><%=tc[i%5]%>;">
                                        <%= b.name.charAt(0).toUpperCase() %>
                                    </div>
                                    <div>
                                        <div class="borrower-name"><a href="/members/<%= b.id %>"><%= b.name %></a></div>
                                        <div class="borrower-loans"><%= b.loan_count %> loan<%= b.loan_count != 1 ? 's' : '' %></div>
                                    </div>
                                    <div class="borrower-amount">UGX&nbsp;<%= parseFloat(b.total_borrowed).toLocaleString() %></div>
                                </div>
                            <% }); %>
                        <% } else { %>
                            <p class="text-center text-muted" style="font-size:.8rem; padding:20px 0;">No borrowers yet</p>
                        <% } %>
                    </div>
                </div>

            </div>

            <!-- ══ ROW 3: Recent Transactions ══════════════════════════ -->
            <div class="card-panel fade-up delay-6">
                <div class="card-panel__head">
                    <div class="card-panel__title">
                        <i class="fa fa-exchange text-success"></i> Recent Transactions
                    </div>
                    <a href="/transaction_list" class="btn-pill btn-pill-green">View All</a>
                </div>
                <div class="table-scroll">
                    <table class="txn-table">
                        <thead>
                            <tr>
                                <th class="col-id">#</th>
                                <th>Member</th>
                                <th>Amount</th>
                                <th class="col-type">Type</th>
                                <th class="col-date">Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            <% if (recentTransactions && recentTransactions.length > 0) { %>
                                <% recentTransactions.forEach(function(txn) { %>
                                    <tr>
                                        <td class="col-id" style="color:var(--ink-3);font-size:.7rem;">#<%= txn.id %></td>
                                        <td>
                                            <a href="/members/<%= txn.member_id %>"><%= txn.member_name %></a>
                                        </td>
                                        <td>
                                            <span class="<%= txn.Debit_Credit==='Credit' ? 'amount-credit' : 'amount-debit' %>">
                                                <%= txn.Debit_Credit==='Credit' ? '+' : '-' %> UGX&nbsp;<%= parseFloat(txn.Amount).toLocaleString() %>
                                            </span>
                                        </td>
                                        <td class="col-type">
                                            <span class="badge-type <%= txn.Debit_Credit==='Credit' ? 'badge-credit' : 'badge-debit' %>">
                                                <%= txn.transaction_type %>
                                            </span>
                                        </td>
                                        <td class="col-date" style="color:var(--ink-3);white-space:nowrap;"><%= txn.tran_date %></td>
                                    </tr>
                                <% }); %>
                            <% } else { %>
                                <tr><td colspan="5" style="text-align:center;color:var(--ink-3);padding:24px;font-size:.8rem;">No transactions found</td></tr>
                            <% } %>
                        </tbody>
                    </table>
                </div>
            </div>

        </div><!-- /page-content -->

        <footer class="page-footer">
            <div class="font-13">2025 © <b>Fincas</b> - All rights reserved.</div>
            <a class="px-4" href="#" target="_blank">Contact Us</a>
            <div class="to-top"><i class="fa fa-angle-double-up"></i></div>
        </footer>
    </div>
</div>

<!-- Scripts -->
<script src="./assets/vendors/jquery/dist/jquery.min.js"></script>
<script src="./assets/vendors/popper.js/dist/umd/popper.min.js"></script>
<script src="./assets/vendors/bootstrap/dist/js/bootstrap.min.js"></script>
<script src="./assets/vendors/metisMenu/dist/metisMenu.min.js"></script>
<script src="./assets/vendors/jquery-slimscroll/jquery.slimscroll.min.js"></script>
<script src="./assets/vendors/chart.js/dist/Chart.min.js"></script>
<script src="assets/js/app.min.js"></script>

<script>
$(function () {
    'use strict';

    function ugx(n) {
        return 'UGX\u00a0' + parseFloat(n).toLocaleString('en-UG', { maximumFractionDigits: 0 });
    }

    var COLORS = {
        green:      'rgba(0,184,148,.8)',
        greenLine:  'rgba(0,184,148,1)',
        blue:       'rgba(9,132,227,.8)',
        blueLine:   'rgba(9,132,227,1)',
        amber:      'rgba(225,112,85,.8)',
        amberLine:  'rgba(225,112,85,1)',
    };

    var LIQ_COLORS = [
        'rgba(9,132,227,.85)',
        'rgba(0,184,148,.85)',
        'rgba(225,112,85,.85)',
        'rgba(214,48,49,.85)',
        'rgba(108,92,231,.85)',
        'rgba(253,126,20,.85)',
        'rgba(32,201,151,.85)'
    ];

    /* ── 1. Bar Chart ───────────────────────────────────────────── */
    new Chart(document.getElementById('bar_chart'), {
        type: 'bar',
        data: {
            labels: ['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'],
            datasets: [
                {
                    label: 'Savings',
                    backgroundColor: COLORS.green,
                    borderColor: COLORS.greenLine,
                    borderWidth: 1,
                    borderRadius: 4,
                    data: <%- savingsData %>
                },
                {
                    label: 'Income',
                    backgroundColor: COLORS.amber,
                    borderColor: COLORS.amberLine,
                    borderWidth: 1,
                    borderRadius: 4,
                    data: <%- incomeData %>
                },
                {
                    label: 'Loans',
                    backgroundColor: COLORS.blue,
                    borderColor: COLORS.blueLine,
                    borderWidth: 1,
                    borderRadius: 4,
                    data: <%- loansData %>
                }
            ]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            legend: {
                display: true,
                position: 'top',
                labels: { fontSize: 11, fontFamily: "'DM Sans', sans-serif", boxWidth: 10, padding: 16 }
            },
            scales: {
                xAxes: [{ gridLines: { display: false }, ticks: { fontSize: 10, fontFamily: "'DM Sans', sans-serif" } }],
                yAxes: [{
                    gridLines: { color: 'rgba(0,0,0,.04)', zeroLineColor: 'rgba(0,0,0,.08)' },
                    ticks: {
                        beginAtZero: true,
                        fontSize: 10,
                        fontFamily: "'DM Mono', monospace",
                        callback: function(v) {
                            if (v >= 1e6) return (v/1e6).toFixed(1)+'M';
                            if (v >= 1e3) return (v/1e3).toFixed(0)+'K';
                            return v;
                        }
                    }
                }]
            },
            tooltips: {
                backgroundColor: '#1a1f2e',
                titleFontFamily: "'DM Sans', sans-serif",
                bodyFontFamily:  "'DM Mono', monospace",
                titleFontSize: 11,
                bodyFontSize:  11,
                cornerRadius: 8,
                callbacks: {
                    label: function(item, data) {
                        return ' ' + data.datasets[item.datasetIndex].label + ': ' +
                               parseFloat(item.yLabel).toLocaleString('en-UG', { maximumFractionDigits: 0 });
                    }
                }
            }
        }
    });

    /* ── 2. Doughnut Chart ──────────────────────────────────────── */
    new Chart(document.getElementById('doughnut_chart'), {
        type: 'doughnut',
        data: {
            labels: ['Loan Interest','Penalties','Fees'],
            datasets: [{
                data: [<%= interestIncome %>, <%= penaltyIncome %>, <%= feeIncome %>],
                backgroundColor: [COLORS.green, COLORS.amber, COLORS.blue],
                borderColor:     [COLORS.greenLine, COLORS.amberLine, COLORS.blueLine],
                borderWidth: 2
            }]
        },
        options: {
            responsive: true,
            maintainAspectRatio: false,
            cutoutPercentage: 68,
            legend: { display: false },
            tooltips: {
                backgroundColor: '#1a1f2e',
                titleFontFamily: "'DM Sans', sans-serif",
                bodyFontFamily:  "'DM Mono', monospace",
                titleFontSize: 11,
                bodyFontSize:  11,
                cornerRadius: 8,
                callbacks: {
                    label: function(item, d) {
                        return ' ' + d.labels[item.index] + ': ' +
                               parseFloat(d.datasets[0].data[item.index]).toLocaleString();
                    }
                }
            }
        }
    });

    /* ── 3. Liquidity Pie ───────────────────────────────────────── */
    var liqChart = null;

    fetch('/liquidity/summary')
        .then(function(r){ return r.json(); })
        .then(function(data){
            var cats   = data.categories || [];
            var total  = data.total || 0;
            var labels = cats.map(function(c){ return c.category; });
            var values = cats.map(function(c){ return parseFloat(c.total_amount); });
            var colors = LIQ_COLORS.slice(0, labels.length);

            if (liqChart) liqChart.destroy();

            if (values.length === 0) {
                document.getElementById('liquidity_legend').innerHTML =
                    '<li style="color:var(--ink-3);font-size:.75rem;">No data yet. <a href="/liquidity_report">Add funds</a></li>';
                document.getElementById('liquidity_total').textContent = 'UGX 0';
                return;
            }

            liqChart = new Chart(document.getElementById('liquidity_chart'), {
                type: 'pie',
                data: {
                    labels: labels,
                    datasets: [{
                        data: values,
                        backgroundColor: colors,
                        borderColor: '#fff',
                        borderWidth: 2
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    legend: { display: false },
                    tooltips: {
                        backgroundColor: '#1a1f2e',
                        titleFontFamily: "'DM Sans', sans-serif",
                        bodyFontFamily:  "'DM Mono', monospace",
                        cornerRadius: 8,
                        callbacks: {
                            label: function(item, d){
                                var v   = d.datasets[0].data[item.index];
                                var pct = total > 0 ? ((v/total)*100).toFixed(1) : 0;
                                return ' ' + d.labels[item.index]+': '+
                                       parseFloat(v).toLocaleString()+' ('+pct+'%)';
                            }
                        }
                    }
                }
            });

            /* Legend */
            var legHtml = '<ul class="liq-legend">';
            cats.forEach(function(c, i){
                var pct = total > 0 ? ((parseFloat(c.total_amount)/total)*100).toFixed(1) : 0;
                legHtml += '<li>' +
                    '<span class="liq-dot" style="background:'+LIQ_COLORS[i]+'"></span>' +
                    '<span>'+c.category+'</span>' +
                    '<span class="liq-legend__pct">'+pct+'%</span>' +
                    '</li>';
            });
            legHtml += '</ul>';
            document.getElementById('liquidity_legend').innerHTML = legHtml;

            /* List */
            var lstHtml = '';
            cats.forEach(function(c, i){
                lstHtml += '<li>' +
                    '<span class="liq-dot" style="background:'+LIQ_COLORS[i]+'"></span>' +
                    '<span>'+c.category+'</span>' +
                    '<span class="liq-val">'+parseFloat(c.total_amount).toLocaleString()+'</span>' +
                    '</li>';
            });
            document.getElementById('liquidity_list').innerHTML = lstHtml;
            document.getElementById('liquidity_total').textContent = parseFloat(total).toLocaleString('en-UG', { maximumFractionDigits: 0 });
        })
        .catch(function(){
            document.getElementById('liquidity_legend').innerHTML =
                '<li style="color:var(--red);font-size:.75rem;"><i class="fa fa-exclamation-circle"></i> Failed to load</li>';
        });

});
</script>
</body>
</html>
