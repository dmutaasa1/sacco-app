        <script>
        document.getElementById('memberadd').addEventListener('submit', async function(e) {
            e.preventDefault(); // prevent normal page reload

            const formData = new FormData(this);
            const data = Object.fromEntries(formData.entries()); // convert to object

            try {
                const response = await fetch('/memberadd', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                const result = await response.json();

                if (!response.ok) {
                    Swal.fire({
                        icon: 'error',
                        title: 'Validation Errors',
                        html: result.errors.map(err => `<p>${err}</p>`).join('')
                    });
                    return;
                }

                const formattedDate = new Date(result.memberadd.date_of_birth)
                                        .toLocaleDateString('en-GB', { day:'2-digit', month:'short', year:'numeric' });                

                const status = result.memberadd.status.toLowerCase() === 'Active' ? 'green' : 'red';

                Swal.fire({
                    icon: 'success',
                    title: 'Member added Successfully',
                    html: `
                        <b>First Name:</b> ${result.memberadd.First_name}<br>
                        <b>Last Name:</b> ${result.memberadd.Last_Name}<br>
                        <b>Mobile Number:</b>${result.memberadd.tel_no} <br>
                        <b>Gender:</b> ${result.memberadd.sex}<br>
                        <b>Date of Birth:</b> ${formattedDate}<br>
                        <b>Employment:</b> ${result.memberadd.occupation}<br>
                        <b>Status:</b> ${result.memberadd.status}
                    `,
                    confirmButtonText: 'OK'
                }).then(() => {
                    window.location.href = '/member_add';
                });

            } catch (err) {
                Swal.fire({
                    icon: 'error',
                    title: 'Server Error',
                    text: err.message || JSON.stringify(err)
                });
            }


        });



        </script>

