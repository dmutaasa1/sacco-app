<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap');

/* ═══════════════════════════════════════════
   HEADER  —  height 60px  |  brand 220px
   Same dark bg as sidebar: #0f1623
═══════════════════════════════════════════ */
.header {
    height: 60px;
    background: #fff;
    border-bottom: 1px solid #e8ecf0;
    display: flex;
    align-items: center;
    padding: 0;
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 999;
    box-shadow: 0 1px 8px rgba(26,31,46,.07);
    font-family: 'DM Sans', sans-serif;
    transition: none;
}

/* ── BRAND BLOCK — exactly 220px, same dark bg as sidebar ── */
.page-brand {
    width: 220px;
    height: 60px;
    background: #0f1623;          /* ← must match sidebar bg */
    border-right: 1px solid rgba(255,255,255,.04);
    display: flex;
    align-items: center;
    padding: 0 14px;
    flex-shrink: 0;
    transition: width .22s ease;
    overflow: hidden;
}
.page-brand .link {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
    width: 100%;
}
.brand-logo-mark {
    width: 34px; height: 34px;
    border-radius: 9px;
    background: linear-gradient(135deg, #00b894, #0984e3);
    display: flex; align-items: center; justify-content: center;
    font-size: 13px; font-weight: 800; color: #fff;
    letter-spacing: -.5px; flex-shrink: 0;
}
.brand-text {
    display: flex; flex-direction: column; line-height: 1;
    overflow: hidden;
    transition: opacity .15s, width .22s;
    white-space: nowrap;
}
.brand-name { font-size: .88rem; font-weight: 700; color: #f0f4ff; letter-spacing: -.2px; }
.brand-sub  { font-size: .6rem; font-weight: 500; color: #00b894; text-transform: uppercase; letter-spacing: .8px; margin-top: 3px; }

/* ── COLLAPSED state: brand shrinks to just the logo mark ── */
body.sidebar-collapsed .page-brand {
    width: 60px;
    padding: 0;
    justify-content: center;
}
body.sidebar-collapsed .page-brand .link { justify-content: center; gap: 0; }
body.sidebar-collapsed .brand-text { opacity: 0; width: 0; overflow: hidden; }

/* ── TOOLBAR ── */
.header-toolbar {
    flex: 1; display: flex; align-items: center;
    justify-content: space-between;
    padding: 0 16px; height: 100%;
}
.toolbar-left  { display: flex; align-items: center; gap: 8px; }
.toolbar-right { display: flex; align-items: center; gap: 4px; }

.hdr-icon-btn {
    width: 34px; height: 34px; border-radius: 9px;
    border: none; background: transparent;
    display: flex; align-items: center; justify-content: center;
    color: #718096; font-size: .95rem; cursor: pointer;
    transition: background .15s, color .15s;
    text-decoration: none; flex-shrink: 0;
}
.hdr-icon-btn:hover { background: #f0f4f8; color: #1a1f2e; text-decoration: none; }

/* ═══════════════════════════════════════════
   LIVE SEARCH
═══════════════════════════════════════════ */
.hdr-search {
    position: relative;
    display: flex; align-items: center;
}
.hdr-search__icon {
    position: absolute; left: 10px;
    color: #a0aec0; font-size: .78rem;
    pointer-events: none; z-index: 2;
    transition: color .15s;
}
.hdr-search input {
    height: 34px; border: 1px solid #e2e8f0; border-radius: 9px;
    padding: 0 32px 0 32px; font-size: .78rem;
    font-family: 'DM Sans', sans-serif; color: #1a1f2e;
    background: #f7fafc; outline: none; width: 220px;
    transition: border-color .15s, box-shadow .15s, width .2s;
}
.hdr-search input:focus {
    border-color: #00b894;
    box-shadow: 0 0 0 3px rgba(0,184,148,.1);
    background: #fff; width: 270px;
}
.hdr-search input::placeholder { color: #b0bec5; }
.hdr-search.focused .hdr-search__icon { color: #00b894; }

.hdr-search__clear {
    position: absolute; right: 8px;
    width: 17px; height: 17px; border-radius: 50%;
    background: #cbd5e0; color: #fff;
    display: none; align-items: center; justify-content: center;
    font-size: .58rem; cursor: pointer; border: none; z-index: 2;
}
.hdr-search__clear:hover { background: #a0aec0; }
.hdr-search__clear.visible { display: flex; }

/* Results dropdown */
.hdr-search-results {
    position: absolute; top: calc(100% + 7px); left: 0;
    width: 360px; background: #fff;
    border: 1px solid #e8ecf0; border-radius: 12px;
    box-shadow: 0 8px 32px rgba(26,31,46,.13);
    z-index: 9999; display: none;
    max-height: 400px; overflow-y: auto;
}
.hdr-search-results.open { display: block; }

.hsr-section-label {
    font-size: .6rem; font-weight: 700; letter-spacing: 1px;
    text-transform: uppercase; color: #a0aec0;
    padding: 10px 14px 4px;
}
.hsr-item {
    display: flex; align-items: center; gap: 10px;
    padding: 8px 14px; cursor: pointer;
    transition: background .12s;
    text-decoration: none;
}
.hsr-item:hover { background: #f7fafc; text-decoration: none; }
.hsr-avatar {
    width: 30px; height: 30px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: .68rem; font-weight: 700; color: #fff; flex-shrink: 0;
}
.hsr-info { min-width: 0; }
.hsr-name  { font-size: .78rem; font-weight: 600; color: #1a1f2e; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.hsr-meta  { font-size: .67rem; color: #a0aec0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.hsr-divider { height: 1px; background: #f0f4f8; margin: 4px 0; }
.hsr-state {
    padding: 18px 14px; color: #a0aec0; font-size: .78rem;
    display: flex; align-items: center; gap: 8px;
}

/* ═══════════════════════════════════════════
   NOTIFICATIONS
═══════════════════════════════════════════ */
.notif-wrap { position: relative; }
.notif-badge {
    position: absolute; top: 3px; right: 3px;
    min-width: 16px; height: 16px; border-radius: 8px;
    background: #e53e3e; color: #fff;
    font-size: .55rem; font-weight: 700;
    display: none; align-items: center; justify-content: center;
    padding: 0 3px; line-height: 1;
    border: 2px solid #fff;
}
.notif-badge.visible { display: flex; }

.notif-dropdown {
    position: absolute; top: calc(100% + 8px); right: -8px;
    width: 320px; background: #fff;
    border: 1px solid #e8ecf0; border-radius: 12px;
    box-shadow: 0 8px 32px rgba(26,31,46,.13);
    z-index: 9999; display: none; overflow: hidden;
}
.notif-dropdown.open { display: block; }

.notif-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 12px 14px 10px;
    border-bottom: 1px solid #f0f4f8;
}
.notif-header-title { font-size: .82rem; font-weight: 700; color: #1a1f2e; }
.notif-mark-all {
    font-size: .68rem; color: #00b894; cursor: pointer;
    background: none; border: none; padding: 0; font-family: inherit;
}
.notif-mark-all:hover { text-decoration: underline; }

.notif-list { max-height: 320px; overflow-y: auto; }
.notif-item {
    display: flex; gap: 10px; padding: 10px 14px;
    border-bottom: 1px solid #f7fafc;
    transition: background .12s; cursor: pointer;
}
.notif-item:hover { background: #f7fafc; }
.notif-item.unread { background: #f0fdf9; }
.notif-item.unread:hover { background: #e6faf4; }
.notif-icon {
    width: 30px; height: 30px; border-radius: 8px;
    display: flex; align-items: center; justify-content: center;
    font-size: .72rem; flex-shrink: 0; margin-top: 1px;
}
.notif-body { min-width: 0; }
.notif-title { font-size: .75rem; font-weight: 600; color: #1a1f2e; line-height: 1.3; }
.notif-msg   { font-size: .68rem; color: #718096; margin-top: 2px; line-height: 1.35; }
.notif-time  { font-size: .62rem; color: #b0bec5; margin-top: 3px; }

/* interest calc status colours */
.notif-icon.interest   { background: rgba(0,184,148,.12); color: #00b894; }
.notif-icon.overdue    { background: rgba(229,62,62,.1);  color: #e53e3e; }
.notif-icon.member     { background: rgba(66,153,225,.1); color: #4299e1; }
.notif-icon.loan       { background: rgba(159,122,234,.1);color: #9f7aea; }
.notif-icon.repayment  { background: rgba(72,187,120,.1); color: #48bb78; }
.notif-icon.txn        { background: rgba(237,137,54,.1); color: #ed8936; }
.notif-icon.system     { background: rgba(160,174,192,.12);color: #718096; }

.notif-empty {
    padding: 24px 14px; text-align: center;
    color: #a0aec0; font-size: .78rem;
}
.notif-footer {
    padding: 8px 14px;
    border-top: 1px solid #f0f4f8;
    text-align: center;
}
.notif-footer a { font-size: .72rem; color: #00b894; text-decoration: none; }
.notif-footer a:hover { text-decoration: underline; }

/* Interest calc status pill */
.interest-status-pill {
    display: inline-flex; align-items: center; gap: 5px;
    padding: 4px 10px; border-radius: 20px;
    font-size: .65rem; font-weight: 600;
    background: rgba(0,184,148,.1); color: #00b894;
    margin-left: 4px;
}
.interest-status-pill.running { background: rgba(237,137,54,.12); color: #ed8936; }
.interest-status-pill.error   { background: rgba(229,62,62,.1);  color: #e53e3e; }
.interest-status-pill i { font-size: .6rem; }

/* ═══════════════════════════════════════════
   USER MENU
═══════════════════════════════════════════ */
.usr-wrap { position: relative; }
.usr-btn {
    display: flex; align-items: center; gap: 8px;
    padding: 4px 8px 4px 4px; border-radius: 10px;
    border: none; background: transparent; cursor: pointer;
    font-family: 'DM Sans', sans-serif;
    transition: background .15s;
}
.usr-btn:hover { background: #f0f4f8; }
.usr-avatar {
    width: 30px; height: 30px; border-radius: 8px;
    background: linear-gradient(135deg, #00b894, #0984e3);
    display: flex; align-items: center; justify-content: center;
    font-size: .72rem; font-weight: 700; color: #fff; flex-shrink: 0;
}
.usr-name { font-size: .78rem; font-weight: 600; color: #1a1f2e; }
.usr-chevron { font-size: .6rem; color: #a0aec0; transition: transform .18s; }
.usr-btn.open .usr-chevron { transform: rotate(180deg); }

.usr-dropdown {
    position: absolute; top: calc(100% + 8px); right: 0;
    width: 180px; background: #fff;
    border: 1px solid #e8ecf0; border-radius: 10px;
    box-shadow: 0 8px 24px rgba(26,31,46,.11);
    z-index: 9999; display: none; overflow: hidden;
    padding: 4px;
}
.usr-dropdown.open { display: block; }
.hdr-menu-item {
    display: flex; align-items: center; gap: 8px;
    padding: 8px 10px; border-radius: 7px;
    font-size: .76rem; color: #4a5568; cursor: pointer;
    text-decoration: none; transition: background .12s;
}
.hdr-menu-item:hover { background: #f7fafc; text-decoration: none; }
.hdr-menu-item i { width: 14px; text-align: center; color: #a0aec0; }
.hdr-menu-divider { height: 1px; background: #f0f4f8; margin: 3px 0; }
.hdr-menu-item--danger { color: #e53e3e; }
.hdr-menu-item--danger i { color: #e53e3e; }
.hdr-menu-item--danger:hover { background: rgba(229,62,62,.06); }

@media (max-width: 640px) {
    .hdr-search { display: none; }
    .usr-name   { display: none; }
}
</style>

<header class="header">

    <!-- Brand — collapses to logo-only when sidebar is collapsed -->
    <div class="page-brand">
        <a class="link" href="/">
            <div class="brand-logo-mark">AW</div>
            <div class="brand-text">
                <span class="brand-name">Agali</span>
                <span class="brand-sub">Awamu</span>
            </div>
        </a>
    </div>

    <!-- Toolbar -->
    <div class="header-toolbar">

        <!-- LEFT -->
        <div class="toolbar-left">

            <!-- Sidebar toggle -->
            <button class="hdr-icon-btn" id="sidebarToggleBtn" title="Toggle sidebar" style="border:none;">
                <i class="fa fa-bars"></i>
            </button>

            <!-- Live search -->
            <div class="hdr-search" id="hdrSearch">
                <i class="hdr-search__icon fa fa-search"></i>
                <input type="text" id="hdrSearchInput"
                    placeholder="Search members or dependants…"
                    autocomplete="off" spellcheck="false" />
                <button class="hdr-search__clear" id="hdrSearchClear" type="button">
                    <i class="fa fa-times"></i>
                </button>
                <div class="hdr-search-results" id="hdrSearchResults">
                    <div class="hsr-state"><i class="fa fa-search"></i>&nbsp; Start typing to search…</div>
                </div>
            </div>

        </div>

        <!-- RIGHT -->
        <div class="toolbar-right">

            <!-- Interest calculation status pill -->
            <span class="interest-status-pill" id="interestStatusPill" style="display:none;">
                <i class="fa fa-calculator"></i>
                <span id="interestStatusText">Calculating…</span>
            </span>

            <!-- Notifications bell -->
            <div class="notif-wrap">
                <button class="hdr-icon-btn" id="notifBtn" type="button" style="position:relative;border:none;">
                    <i class="fa fa-bell-o"></i>
                    <span class="notif-badge" id="notifBadge"></span>
                </button>
                <div class="notif-dropdown" id="notifDropdown">
                    <div class="notif-header">
                        <span class="notif-header-title">Notifications</span>
                        <button class="notif-mark-all" id="markAllRead" type="button">Mark all read</button>
                    </div>
                    <div class="notif-list" id="notifList">
                        <div class="notif-empty"><i class="fa fa-spinner fa-spin"></i>&nbsp; Loading…</div>
                    </div>
                    <div class="notif-footer"><a href="/notifications">View all</a></div>
                </div>
            </div>

            <!-- User menu -->
            <div class="usr-wrap">
                <button class="usr-btn" id="usrBtn" type="button">
                    <div class="usr-avatar" id="usrAvatar">
                        <%= (user.first_name || 'U').charAt(0).toUpperCase() %><%= (user.last_name  || '').charAt(0).toUpperCase() %>
                    </div>
                    <span class="usr-name"><%= user.first_name %></span>
                    <i class="fa fa-chevron-down usr-chevron"></i>
                </button>
                <div class="usr-dropdown" id="usrDropdown">
                    <a href="/profile" class="hdr-menu-item"><i class="fa fa-user-o"></i> Profile</a>
                    <a href="/settings" class="hdr-menu-item"><i class="fa fa-cog"></i> Settings</a>
                    <div class="hdr-menu-divider"></div>
                    <a href="/logout" class="hdr-menu-item hdr-menu-item--danger"><i class="fa fa-power-off"></i> Sign Out</a>
                </div>
            </div>

        </div>
    </div>
</header>

<script>
(function () {

    /* ═══════════════════════════════════════════
       SIDEBAR TOGGLE
       Adds/removes body.sidebar-collapsed
       Both header brand and sidebar respond via CSS
    ═══════════════════════════════════════════ */
    var toggleBtn = document.getElementById('sidebarToggleBtn');
    if (toggleBtn) {
        // Restore saved preference
        if (localStorage.getItem('sidebarCollapsed') === '1') {
            document.body.classList.add('sidebar-collapsed');
        }
        toggleBtn.addEventListener('click', function () {
            document.body.classList.toggle('sidebar-collapsed');
            localStorage.setItem('sidebarCollapsed',
                document.body.classList.contains('sidebar-collapsed') ? '1' : '0');
        });
    }

    /* ═══════════════════════════════════════════
       LIVE SEARCH
    ═══════════════════════════════════════════ */
    var searchWrap   = document.getElementById('hdrSearch');
    var searchInput  = document.getElementById('hdrSearchInput');
    var searchClear  = document.getElementById('hdrSearchClear');
    var searchResult = document.getElementById('hdrSearchResults');
    var searchTimer  = null;

    var AVATAR_COLORS = ['#0984e3','#00b894','#6c5ce7','#e17055','#00cec9','#fd79a8'];
    function avatarColor(str) {
        var n = 0;
        for (var i = 0; i < (str||'').length; i++) n += str.charCodeAt(i);
        return AVATAR_COLORS[n % AVATAR_COLORS.length];
    }
    function initials(f, l) {
        return ((f||'')[0]||'').toUpperCase() + ((l||'')[0]||'').toUpperCase();
    }

    function renderResults(data) {
        var members   = data.members   || [];
        var dependants= data.dependants|| [];

        if (!members.length && !dependants.length) {
            searchResult.innerHTML = '<div class="hsr-state"><i class="fa fa-search"></i>&nbsp; No results found.</div>';
            searchResult.classList.add('open');
            return;
        }

        var html = '';

        if (members.length) {
            html += '<div class="hsr-section-label">Members</div>';
            members.forEach(function (m) {
                var ini = initials(m.First_name, m.Last_Name);
                var col = avatarColor(ini);
                html += '<a class="hsr-item" href="/member_view/' + m.id + '">' +
                    '<div class="hsr-avatar" style="background:' + col + '">' + ini + '</div>' +
                    '<div class="hsr-info">' +
                        '<div class="hsr-name">' + (m.First_name||'') + ' ' + (m.Last_Name||'') + '</div>' +
                        '<div class="hsr-meta">ID: ' + m.id + (m.tel_no ? ' &middot; ' + m.tel_no : '') + (m.email ? ' &middot; ' + m.email : '') + '</div>' +
                    '</div></a>';
            });
        }

        if (dependants.length) {
            if (members.length) html += '<div class="hsr-divider"></div>';
            html += '<div class="hsr-section-label">Dependants</div>';
            dependants.forEach(function (d) {
                var ini = initials(d.First_name, d.Last_Name);
                var col = avatarColor(ini + 'dep');
                html += '<a class="hsr-item" href="/dependant_view/' + d.id + '">' +
                    '<div class="hsr-avatar" style="background:' + col + '">' + ini + '</div>' +
                    '<div class="hsr-info">' +
                        '<div class="hsr-name">' + (d.First_name||'') + ' ' + (d.Last_Name||'') + '</div>' +
                        '<div class="hsr-meta">ID: ' + d.id + ' &middot; ' + (d.member_name||'') + (d.relationship ? ' &middot; ' + d.relationship : '') + '</div>' +
                    '</div></a>';
            });
        }

        searchResult.innerHTML = html;
        searchResult.classList.add('open');
    }

    function doSearch(q) {
        q = (q || '').trim();
        if (!q) {
            searchResult.classList.remove('open');
            searchResult.innerHTML = '<div class="hsr-state"><i class="fa fa-search"></i>&nbsp; Start typing to search…</div>';
            return;
        }
        searchResult.innerHTML = '<div class="hsr-state"><i class="fa fa-spinner fa-spin"></i>&nbsp; Searching…</div>';
        searchResult.classList.add('open');

        fetch('/search?q=' + encodeURIComponent(q) + '&limit=6', {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function (r) {
            if (!r.ok) throw new Error('HTTP ' + r.status + ' — is GET /search defined in app.js?');
            return r.json();
        })
        .then(function (data) { renderResults(data); })
        .catch(function (err) {
            searchResult.innerHTML =
                '<div class="hsr-state" style="flex-direction:column;align-items:flex-start;gap:3px;">' +
                '<span style="color:#e53e3e;"><i class="fa fa-exclamation-circle"></i> ' + err.message + '</span>' +
                '<small style="color:#a0aec0;font-size:.65rem;">Check browser console (F12) for details.</small>' +
                '</div>';
        });
    }

    if (searchInput) {
        searchInput.addEventListener('focus', function () {
            searchWrap.classList.add('focused');
            if (this.value.trim()) searchResult.classList.add('open');
        });
        searchInput.addEventListener('blur', function () {
            searchWrap.classList.remove('focused');
        });
        searchInput.addEventListener('input', function () {
            var val = this.value;
            searchClear.classList.toggle('visible', val.length > 0);
            clearTimeout(searchTimer);
            if (!val.trim()) {
                searchResult.classList.remove('open');
                return;
            }
            searchTimer = setTimeout(function () { doSearch(val); }, 300);
        });
        searchInput.addEventListener('keydown', function (e) {
            if (e.key === 'Escape') { searchResult.classList.remove('open'); this.blur(); }
        });
        searchClear.addEventListener('click', function (e) {
            e.stopPropagation();
            searchInput.value = '';
            searchClear.classList.remove('visible');
            searchResult.classList.remove('open');
            searchInput.focus();
        });
        document.addEventListener('click', function (e) {
            if (!searchWrap.contains(e.target)) searchResult.classList.remove('open');
        });
    }

    /* ═══════════════════════════════════════════
       NOTIFICATIONS  — fetches from /notifications
       Shows interest calculation status as a pill
    ═══════════════════════════════════════════ */
    var notifBtn      = document.getElementById('notifBtn');
    var notifDropdown = document.getElementById('notifDropdown');
    var notifList     = document.getElementById('notifList');
    var notifBadge    = document.getElementById('notifBadge');
    var markAllBtn    = document.getElementById('markAllRead');
    var intPill       = document.getElementById('interestStatusPill');
    var intText       = document.getElementById('interestStatusText');
    var notifOpen     = false;
    var pollTimer     = null;

    var TYPE_MAP = {
        interest   : { icon: 'fa-calculator', cls: 'interest',  label: 'Interest' },
        overdue    : { icon: 'fa-exclamation-circle', cls: 'overdue', label: 'Overdue' },
        member     : { icon: 'fa-user-plus',  cls: 'member',    label: 'Member' },
        loan       : { icon: 'fa-money',      cls: 'loan',      label: 'Loan' },
        repayment  : { icon: 'fa-check-circle', cls: 'repayment', label: 'Repayment' },
        transaction: { icon: 'fa-exchange',   cls: 'txn',       label: 'Transaction' },
        system     : { icon: 'fa-info-circle',cls: 'system',    label: 'System' }
    };

    function timeAgo(dateStr) {
        var now  = new Date();
        var then = new Date(dateStr);
        var s    = Math.floor((now - then) / 1000);
        if (s < 60)   return 'just now';
        if (s < 3600) return Math.floor(s/60) + 'm ago';
        if (s < 86400)return Math.floor(s/3600) + 'h ago';
        return Math.floor(s/86400) + 'd ago';
    }

    function renderNotifications(items) {
        if (!items || !items.length) {
            notifList.innerHTML = '<div class="notif-empty"><i class="fa fa-bell-o"></i><br>No notifications yet</div>';
            return;
        }
        var unread = 0;
        var html   = '';
        items.forEach(function (n) {
            var t   = TYPE_MAP[n.type] || TYPE_MAP.system;
            var cls = n.read ? '' : 'unread';
            if (!n.read) unread++;
            html += '<div class="notif-item ' + cls + '" data-id="' + n.id + '" onclick="markRead(' + n.id + ',this)">' +
                '<div class="notif-icon ' + t.cls + '"><i class="fa ' + t.icon + '"></i></div>' +
                '<div class="notif-body">' +
                    '<div class="notif-title">' + (n.title || t.label) + '</div>' +
                    '<div class="notif-msg">' + (n.message || '') + '</div>' +
                    '<div class="notif-time">' + timeAgo(n.created_at) + '</div>' +
                '</div></div>';
        });
        notifList.innerHTML = html;
        if (unread > 0) {
            notifBadge.textContent = unread > 99 ? '99+' : unread;
            notifBadge.classList.add('visible');
        } else {
            notifBadge.classList.remove('visible');
        }

        /* Show interest status pill from latest interest notification */
        var latest = items.find(function(n){ return n.type === 'interest'; });
        if (latest) {
            var status = latest.status || 'done';
            intPill.style.display = 'inline-flex';
            intPill.className = 'interest-status-pill' + (status === 'running' ? ' running' : status === 'error' ? ' error' : '');
            if (status === 'running') {
                intText.textContent = 'Calculating…';
                intPill.querySelector('i').className = 'fa fa-spinner fa-spin';
            } else if (status === 'error') {
                intText.textContent = 'Calc Error';
                intPill.querySelector('i').className = 'fa fa-exclamation-triangle';
            } else {
                intText.textContent = latest.message || 'Interest Applied';
                intPill.querySelector('i').className = 'fa fa-check-circle';
                /* Auto-hide after 8s if it's just informational */
                setTimeout(function () { intPill.style.display = 'none'; }, 8000);
            }
        }
    }

    function fetchNotifications() {
        fetch('/notifications?limit=12', {
            headers: { 'X-Requested-With': 'XMLHttpRequest' }
        })
        .then(function (r) { return r.ok ? r.json() : Promise.reject(r.status); })
        .then(function (data) {
            renderNotifications(data.notifications || data || []);
        })
        .catch(function () {
            notifList.innerHTML = '<div class="notif-empty" style="color:#e53e3e;"><i class="fa fa-exclamation-circle"></i><br>Could not load<br><small style="color:#a0aec0">Add GET /notifications route</small></div>';
        });
    }

    /* Global function so onclick in dynamically-rendered HTML works */
    window.markRead = function (id, el) {
        if (!el) return;
        el.classList.remove('unread');
        fetch('/notifications/' + id + '/read', { method: 'POST' }).catch(function(){});
        var unreadCount = notifList.querySelectorAll('.notif-item.unread').length;
        if (unreadCount > 0) {
            notifBadge.textContent = unreadCount;
        } else {
            notifBadge.classList.remove('visible');
        }
    };

    if (markAllBtn) {
        markAllBtn.addEventListener('click', function () {
            notifList.querySelectorAll('.notif-item.unread').forEach(function (el) {
                el.classList.remove('unread');
            });
            notifBadge.classList.remove('visible');
            fetch('/notifications/read-all', { method: 'POST' }).catch(function(){});
        });
    }

    if (notifBtn) {
        notifBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            notifOpen = !notifOpen;
            notifDropdown.classList.toggle('open', notifOpen);
            if (notifOpen) fetchNotifications();
        });
    }

    /* Poll every 90s */
    fetchNotifications();
    pollTimer = setInterval(fetchNotifications, 90000);

    /* ═══════════════════════════════════════════
       USER DROPDOWN
    ═══════════════════════════════════════════ */
    var usrBtn      = document.getElementById('usrBtn');
    var usrDropdown = document.getElementById('usrDropdown');
    if (usrBtn) {
        usrBtn.addEventListener('click', function (e) {
            e.stopPropagation();
            var open = usrDropdown.classList.toggle('open');
            usrBtn.classList.toggle('open', open);
        });
    }

    /* Close all dropdowns on outside click */
    document.addEventListener('click', function () {
        if (notifDropdown) { notifDropdown.classList.remove('open'); notifOpen = false; }
        if (usrDropdown)   { usrDropdown.classList.remove('open'); }
        if (usrBtn)        { usrBtn.classList.remove('open'); }
    });

}());
</script>
