<style>
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap');

/* ══════════════════════════════════════════════════════
   SIDEBAR  — all rules use !important to override
   main.min.css theme defaults
   Must match header:  width 240px | bg #0f1623 | h 56px
══════════════════════════════════════════════════════ */

/* Force the outer nav to match header brand block exactly */
.page-sidebar,
#sidebar {
    width: 220px !important;
    min-width: 220px !important;
    max-width: 220px !important;
    background: #0f1623 !important;
    border-right: 1px solid rgba(255,255,255,.04) !important;
    position: fixed !important;
    top: 56px !important;       /* flush under 56px header, zero gap */
    left: 0 !important;
    bottom: 0 !important;
    height: calc(100vh - 56px) !important;
    z-index: 998 !important;
    display: flex !important;
    flex-direction: column !important;
    overflow: hidden !important;
    font-family: 'DM Sans', sans-serif !important;
    margin: 0 !important;
    padding: 0 !important;
    box-shadow: none !important;
}

/* Inner scroll container */
#sidebar-collapse {
    display: flex !important;
    flex-direction: column !important;
    flex: 1 !important;
    min-height: 0 !important;
    overflow-y: auto !important;
    overflow-x: hidden !important;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,.12) transparent;
    height: 100% !important;
}
#sidebar-collapse::-webkit-scrollbar       { width: 3px; }
#sidebar-collapse::-webkit-scrollbar-thumb { background: rgba(255,255,255,.15); border-radius: 4px; }

/* ── NAV list ── */
.side-menu {
    list-style: none !important;
    padding: 6px 8px 8px !important;
    margin: 0 !important;
    flex: 1 !important;
    background: transparent !important;
}

/* Section headings */
.side-menu .heading {
    font-size: .57rem !important;
    font-weight: 700 !important;
    letter-spacing: 1.2px !important;
    text-transform: uppercase !important;
    color: rgba(255,255,255,.22) !important;
    padding: 13px 8px 4px !important;
    pointer-events: none !important;
    user-select: none !important;
    background: transparent !important;
    border: none !important;
}

/* Top-level links */
.side-menu > li > a {
    display: flex !important;
    align-items: center !important;
    gap: 9px !important;
    padding: 8px 9px !important;
    border-radius: 8px !important;
    color: rgba(255,255,255,.55) !important;
    font-size: .78rem !important;
    font-weight: 500 !important;
    text-decoration: none !important;
    transition: background .14s, color .14s !important;
    position: relative !important;
    margin-bottom: 1px !important;
    white-space: nowrap !important;
    overflow: hidden !important;
    background: transparent !important;
    border: none !important;
    height: auto !important;
    line-height: normal !important;
}
.side-menu > li > a:hover {
    background: rgba(255,255,255,.07) !important;
    color: rgba(255,255,255,.9) !important;
    text-decoration: none !important;
}

/* Active parent */
.side-menu > li.active > a {
    background: rgba(0,184,148,.13) !important;
    color: #00b894 !important;
}
.side-menu > li.active > a::after {
    content: '' !important;
    position: absolute !important;
    left: 0 !important; top: 18% !important; bottom: 18% !important;
    width: 3px !important;
    border-radius: 0 3px 3px 0 !important;
    background: #00b894 !important;
}

/* Icon pills */
.sidebar-item-icon {
    width: 26px !important; height: 26px !important;
    border-radius: 7px !important;
    background: rgba(255,255,255,.06) !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: .76rem !important;
    flex-shrink: 0 !important;
    transition: background .14s, color .14s !important;
    color: rgba(255,255,255,.55) !important;
}
.side-menu > li > a:hover .sidebar-item-icon {
    background: rgba(255,255,255,.1) !important;
    color: rgba(255,255,255,.9) !important;
}
.side-menu > li.active > a .sidebar-item-icon {
    background: rgba(0,184,148,.18) !important;
    color: #00b894 !important;
}

/* Chevron arrow */
.side-menu .arrow {
    margin-left: auto !important;
    font-size: .58rem !important;
    color: rgba(255,255,255,.2) !important;
    transition: transform .18s, color .14s !important;
    flex-shrink: 0 !important;
}
.side-menu > li > a[aria-expanded="true"] .arrow {
    transform: rotate(-90deg) !important;
    color: rgba(255,255,255,.45) !important;
}
.side-menu > li.active > a .arrow {
    color: rgba(0,184,148,.55) !important;
}

/* Submenu */
.side-menu .nav-2-level {
    list-style: none !important;
    padding: 2px 0 4px 13px !important;
    margin: 0 !important;
    background: transparent !important;
}
.side-menu .nav-2-level li a {
    display: flex !important;
    align-items: center !important;
    gap: 8px !important;
    padding: 6px 9px !important;
    border-radius: 7px !important;
    color: rgba(255,255,255,.38) !important;
    font-size: .73rem !important;
    font-weight: 400 !important;
    text-decoration: none !important;
    transition: background .12s, color .12s !important;
    background: transparent !important;
    border: none !important;
    white-space: nowrap !important;
    overflow: hidden !important;
    text-overflow: ellipsis !important;
}
.side-menu .nav-2-level li a::before {
    content: '' !important;
    width: 4px !important; height: 4px !important;
    border-radius: 50% !important;
    background: rgba(255,255,255,.15) !important;
    flex-shrink: 0 !important;
    transition: background .12s, transform .12s !important;
    display: inline-block !important;
}
.side-menu .nav-2-level li a:hover {
    color: rgba(255,255,255,.85) !important;
    background: rgba(255,255,255,.05) !important;
}
.side-menu .nav-2-level li a:hover::before {
    background: rgba(255,255,255,.45) !important;
}
.side-menu .nav-2-level li a.active {
    color: #00b894 !important;
    background: rgba(0,184,148,.09) !important;
    font-weight: 500 !important;
}
.side-menu .nav-2-level li a.active::before {
    background: #00b894 !important;
    transform: scale(1.4) !important;
}

/* Metismenu collapse */
.side-menu .nav-2-level.collapse         { display: none !important; }
.side-menu .nav-2-level.collapse.in,
.side-menu .nav-2-level.collapsing       { display: block !important; }

/* Bottom dock */
.sb-bottom {
    padding: 8px !important;
    border-top: 1px solid rgba(255,255,255,.06) !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 1px !important;
    flex-shrink: 0 !important;
    background: #0f1623 !important;
}
.sb-bottom__link {
    display: flex !important;
    align-items: center !important;
    gap: 9px !important;
    padding: 7px 9px !important;
    border-radius: 8px !important;
    color: rgba(255,255,255,.38) !important;
    font-size: .74rem !important;
    font-weight: 500 !important;
    text-decoration: none !important;
    transition: background .12s, color .12s !important;
    background: transparent !important;
}
.sb-bottom__link .sb-ico {
    width: 24px !important; height: 24px !important;
    border-radius: 6px !important;
    background: rgba(255,255,255,.05) !important;
    display: flex !important; align-items: center !important; justify-content: center !important;
    font-size: .7rem !important; flex-shrink: 0 !important;
}
.sb-bottom__link:hover {
    background: rgba(255,255,255,.06) !important;
    color: rgba(255,255,255,.85) !important;
}
.sb-bottom__link--danger { color: rgba(220,80,80,.75) !important; }
.sb-bottom__link--danger:hover {
    background: rgba(214,48,49,.1) !important;
    color: #ff7675 !important;
}

/* Zero-height spacer */
.sb-top-pad { height: 0 !important; flex-shrink: 0 !important; }
</style>

<%
function isActive(pages) {
    return pages.includes(currentPage) ? 'active' : '';
}
%>

<nav class="page-sidebar" id="sidebar">
    <div id="sidebar-collapse">

        <div class="sb-top-pad"></div>

        <!-- ── Nav ───────────────────────────────────────── -->
        <ul class="side-menu metismenu">

            <!-- Dashboard -->
            <li class="<%= isActive(['home']) %>">
                <a href="/">
                    <i class="sidebar-item-icon fa fa-home"></i>
                    <span class="nav-label">Dashboard</span>
                </a>
            </li>

            <!-- ════ BIO DATA ════ -->
            <li class="heading">Bio Data</li>

            <!-- Registration -->
            <li class="<%= isActive(['member_add','dependant_add']) %>">
                <a href="javascript:;">
                    <i class="sidebar-item-icon fa fa-user-plus"></i>
                    <span class="nav-label">Registration</span>
                    <i class="fa fa-angle-left arrow"></i>
                </a>
                <ul class="nav-2-level collapse">
                    <li><a class="<%= isActive(['member_add']) %>"     href="/member_add">Add Member</a></li>
                    <li><a class="<%= isActive(['dependant_add']) %>"  href="/dependant_add">Add Dependant</a></li>
                </ul>
            </li>

            <!-- Member Lists -->
            <li class="<%= isActive(['members','Dependants']) %>">
                <a href="javascript:;">
                    <i class="sidebar-item-icon fa fa-users"></i>
                    <span class="nav-label">Member Lists</span>
                    <i class="fa fa-angle-left arrow"></i>
                </a>
                <ul class="nav-2-level collapse">
                    <li><a class="<%= isActive(['members']) %>"    href="/members">Members</a></li>
                    <li><a class="<%= isActive(['Dependants']) %>" href="/Dependants">Dependants</a></li>
                </ul>
            </li>

            <!-- ════ FINANCIALS ════ -->
            <li class="heading">Financials</li>

            <!-- Transactions -->
            <li class="<%= isActive(['transaction','internal_transaction','transaction_list','internal_transaction_listing']) %>">
                <a href="javascript:;">
                    <i class="sidebar-item-icon fa fa-exchange"></i>
                    <span class="nav-label">Transactions</span>
                    <i class="fa fa-angle-left arrow"></i>
                </a>
                <ul class="nav-2-level collapse">
                    <li><a class="<%= isActive(['transaction']) %>"                       href="/transaction">New Member Txn</a></li>
                    <li><a class="<%= isActive(['internal_transaction']) %>"              href="/internal_transaction">New Internal Txn</a></li>
                    <li><a class="<%= isActive(['transaction_list']) %>"                  href="/transaction_list">Member Txn List</a></li>
                    <li><a class="<%= isActive(['internal_transaction_listing']) %>"      href="/internal_transaction_listing">Internal Txn List</a></li>
                </ul>
            </li>

            <!-- Loans -->
            <li class="<%= isActive(['loan_application','loan_list','loan_repayment','Loan_statement']) %>">
                <a href="javascript:;">
                    <i class="sidebar-item-icon fa fa-money"></i>
                    <span class="nav-label">Loans</span>
                    <i class="fa fa-angle-left arrow"></i>
                </a>
                <ul class="nav-2-level collapse">
                    <li><a class="<%= isActive(['loan_application']) %>" href="/loan_application">New Application</a></li>
                    <li><a class="<%= isActive(['loan_list']) %>"        href="/loan_list">Loan List</a></li>
                    <li><a class="<%= isActive(['loan_repayment']) %>"   href="/loan_repayment">Repayments</a></li>
                    <li><a class="<%= isActive(['Loan_statement']) %>"   href="/Loan_statement">Loan Statement</a></li>
                </ul>
            </li>

            <!-- ════ REPORTS ════ -->
            <li class="heading">Reports</li>

            <li class="<%= isActive(['membership_fee','Welfare','Insurance_cover','savings_report','loans_report','liquidity_report','financial_statements']) %>">
                <a href="javascript:;">
                    <i class="sidebar-item-icon fa fa-file-text-o"></i>
                    <span class="nav-label">Reports</span>
                    <i class="fa fa-angle-left arrow"></i>
                </a>
                <ul class="nav-2-level collapse">
                    <li><a class="<%= isActive(['membership_fee']) %>"     href="/membership_fee">Membership Fee</a></li>
                    <li><a class="<%= isActive(['Welfare']) %>"            href="/Welfare">Welfare Fee</a></li>
                    <li><a class="<%= isActive(['Insurance_cover']) %>"    href="/Insurance_cover">Insurance Cover</a></li>
                    <li><a class="<%= isActive(['savings_report']) %>"     href="/savings_report">Savings Report</a></li>
                    <li><a class="<%= isActive(['loans_report']) %>"       href="/loans_report">Loans Report</a></li>
                    <li><a class="<%= isActive(['liquidity_report']) %>"   href="/liquidity_report">Liquidity Report</a></li>
                    <li><a class="<%= isActive(['financial_statements']) %>" href="/financial_statements">Financial Statements</a></li>
                </ul>
            </li>

            <!-- ════ ADMIN ════ -->
            <li class="heading">Admin</li>

            <!-- User Management -->
            <li class="<%= isActive(['users','user_add']) %>">
                <a href="javascript:;">
                    <i class="sidebar-item-icon fa fa-user-secret"></i>
                    <span class="nav-label">User Management</span>
                    <i class="fa fa-angle-left arrow"></i>
                </a>
                <ul class="nav-2-level collapse">
                    <li><a class="<%= isActive(['users']) %>"    href="/users">User List</a></li>
                    <li><a class="<%= isActive(['user_add']) %>" href="/user_add">Add User</a></li>
                </ul>
            </li>

        </ul>

        <!-- ── Bottom dock ───────────────────────────────── -->
        <div class="sb-bottom">
            <a href="/profile" class="sb-bottom__link">
                <span class="sb-ico"><i class="fa fa-user-o"></i></span>
                My Profile
            </a>
            <a href="/settings" class="sb-bottom__link">
                <span class="sb-ico"><i class="fa fa-cog"></i></span>
                Settings
            </a>
            <a href="/logout" class="sb-bottom__link sb-bottom__link--danger">
                <span class="sb-ico"><i class="fa fa-power-off"></i></span>
                Sign Out
            </a>
        </div>

    </div>
</nav>
