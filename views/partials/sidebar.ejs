        </ul>

        <!-- ── Bottom dock ───────────────────────────────── -->
        <div class="sb-bottom">
            <a href="/profile" class="sb-bottom__link">
                <span class="sb-ico"><i class="fa fa-user-o"></i></span>
                My Profile
            </a>
            <a href="/settings" class="sb-bottom__link">
                <span class="sb-ico"><i class="fa fa-cog"></i></span>
                Settings
            </a>
            <a href="/logout" class="sb-bottom__link sb-bottom__link--danger">
                <span class="sb-ico"><i class="fa fa-power-off"></i></span>
                Sign Out
            </a>
        </div>

    </div>
</nav>

<script>
(function () {
    /* Run after jQuery + metismenu + Bootstrap are loaded */
    function initSidebar() {
        if (typeof $ === 'undefined' || !$.fn.metisMenu) {
            /* Scripts not ready yet — retry in 50ms */
            return setTimeout(initSidebar, 50);
        }

        /* 1. Init metismenu on the nav list */
        $('#sidebar .side-menu').metisMenu({
            toggle: true          /* collapse siblings when opening one */
        });

        /* 2. Auto-expand any parent that has an active child */
        $('#sidebar .side-menu li.active').each(function () {
            var $sub = $(this).children('.nav-2-level');
            if ($sub.length) {
                /* Add Bootstrap .in class and set aria-expanded */
                $sub.addClass('in').css('height', '');
                $(this).children('a').attr('aria-expanded', 'true');
            }
        });

        /* 3. Also expand parent if a deep child link has class "active" */
        $('#sidebar .nav-2-level a.active').each(function () {
            var $sub = $(this).closest('.nav-2-level');
            $sub.addClass('in').css('height', '');
            $sub.closest('li').children('a').attr('aria-expanded', 'true');
        });
    }

    /* Start init — works whether this script runs before or after jQuery */
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initSidebar);
    } else {
        initSidebar();
    }
}());
</script>
