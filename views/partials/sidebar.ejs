<%
function isActive(pages) {
    return pages.includes(currentPage) ? 'active' : '';
}
%>

<style>
/* ═══════════════════════════════════════════════════
   SIDEBAR — all rules scoped to #sidebar
   so main.min.css cannot override them.
   bg #0f1623 = identical to header .page-brand
   width 220px | top 60px (matches header height)
═══════════════════════════════════════════════════ */

#sidebar {
    width: 220px;
    background: #0f1623;
    border-right: 1px solid rgba(255,255,255,.04);
    position: fixed;
    top: 60px;
    left: 0;
    bottom: 0;
    height: calc(100vh - 60px);
    z-index: 998;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    font-family: 'DM Sans', sans-serif;
    transition: width .22s ease;
    margin: 0;
    padding: 0;
    box-shadow: none;
}
body.sidebar-collapsed #sidebar { width: 60px; }

/* scroll container */
#sidebar-collapse {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,.1) transparent;
}
#sidebar-collapse::-webkit-scrollbar       { width: 3px; }
#sidebar-collapse::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius: 4px; }

/* nav list */
#sidebar #side-menu {
    list-style: none;
    padding: 4px 7px 8px;
    margin: 0;
    flex: 1;
    background: transparent;
    border: none;
    box-shadow: none;
}

/* section headings */
#sidebar #side-menu > li.heading {
    font-size: .57rem;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: rgba(255,255,255,.2);
    padding: 12px 9px 4px;
    margin: 0;
    pointer-events: none;
    user-select: none;
    white-space: nowrap;
    background: transparent;
    transition: opacity .15s, padding .15s, height .15s;
}
body.sidebar-collapsed #sidebar #side-menu > li.heading {
    opacity: 0; padding: 0; height: 0; overflow: hidden;
}

/* top-level links */
#sidebar #side-menu > li > a {
    display: flex !important;
    align-items: center !important;
    gap: 9px;
    padding: 8px 8px;
    border-radius: 8px;
    color: rgba(255,255,255,.52);
    font-size: .78rem;
    font-weight: 500;
    text-decoration: none !important;
    transition: background .13s, color .13s;
    position: relative;
    margin-bottom: 1px;
    overflow: hidden;
    background: transparent !important;
    border: none !important;
    height: auto !important;
    line-height: 1.3 !important;
    width: 100%;
    white-space: nowrap;
    box-shadow: none !important;
}
#sidebar #side-menu > li > a:hover {
    background: rgba(255,255,255,.07) !important;
    color: rgba(255,255,255,.9) !important;
}
#sidebar #side-menu > li.active > a {
    background: rgba(0,184,148,.13) !important;
    color: #00b894 !important;
}
#sidebar #side-menu > li.active > a::before {
    content: '';
    position: absolute;
    left: 0; top: 14%; bottom: 14%;
    width: 3px; border-radius: 0 3px 3px 0;
    background: #00b894;
}

/* icon pill */
#sidebar .sidebar-item-icon {
    width: 26px; height: 26px;
    border-radius: 7px;
    background: rgba(255,255,255,.06);
    display: inline-flex;
    align-items: center; justify-content: center;
    font-size: .76rem; flex-shrink: 0;
    color: rgba(255,255,255,.5);
    transition: background .13s, color .13s;
}
#sidebar #side-menu > li > a:hover .sidebar-item-icon {
    background: rgba(255,255,255,.1); color: rgba(255,255,255,.88);
}
#sidebar #side-menu > li.active > a .sidebar-item-icon {
    background: rgba(0,184,148,.18); color: #00b894;
}

/* nav label */
#sidebar .nav-label {
    flex: 1; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    transition: opacity .15s;
}
body.sidebar-collapsed #sidebar .nav-label { opacity: 0; width: 0; flex: 0; overflow: hidden; }

/* chevron */
#sidebar .arrow {
    margin-left: auto; font-size: .58rem;
    color: rgba(255,255,255,.2);
    transition: transform .18s, color .13s, opacity .15s;
    flex-shrink: 0;
}
body.sidebar-collapsed #sidebar .arrow { opacity: 0; width: 0; overflow: hidden; }
#sidebar #side-menu > li > a[aria-expanded="true"] > .arrow {
    transform: rotate(-90deg); color: rgba(255,255,255,.45);
}
#sidebar #side-menu > li.active > a .arrow { color: rgba(0,184,148,.5); }

/* submenu — Bootstrap/metismenu controls display, we only style */
#sidebar ul.nav-2-level {
    list-style: none;
    padding: 1px 0 3px 12px;
    margin: 0;
    background: transparent;
}
body.sidebar-collapsed #sidebar ul.nav-2-level { display: none !important; }

#sidebar ul.nav-2-level > li > a {
    display: flex;
    align-items: center;
    gap: 7px;
    padding: 5px 8px;
    border-radius: 6px;
    color: rgba(255,255,255,.37);
    font-size: .72rem; font-weight: 400;
    text-decoration: none;
    transition: background .12s, color .12s;
    background: transparent; border: none;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
    width: 100%;
}
#sidebar ul.nav-2-level > li > a::before {
    content: ''; width: 4px; height: 4px; border-radius: 50%;
    background: rgba(255,255,255,.14); flex-shrink: 0;
    display: inline-block; transition: background .12s, transform .12s;
}
#sidebar ul.nav-2-level > li > a:hover {
    color: rgba(255,255,255,.82); background: rgba(255,255,255,.04);
}
#sidebar ul.nav-2-level > li > a:hover::before { background: rgba(255,255,255,.4); }
#sidebar ul.nav-2-level > li > a.active {
    color: #00b894; background: rgba(0,184,148,.09); font-weight: 500;
}
#sidebar ul.nav-2-level > li > a.active::before { background: #00b894; transform: scale(1.4); }

/* bottom dock */
#sidebar .sb-bottom {
    padding: 7px;
    border-top: 1px solid rgba(255,255,255,.06);
    display: flex; flex-direction: column; gap: 1px;
    flex-shrink: 0; background: #0f1623; overflow: hidden;
}
#sidebar .sb-link {
    display: flex; align-items: center; gap: 8px;
    padding: 7px 8px; border-radius: 7px;
    color: rgba(255,255,255,.38); font-size: .73rem; font-weight: 500;
    text-decoration: none;
    transition: background .12s, color .12s;
    background: transparent; white-space: nowrap; overflow: hidden;
}
#sidebar .sb-ico {
    width: 24px; height: 24px; border-radius: 6px;
    background: rgba(255,255,255,.05);
    display: flex; align-items: center; justify-content: center;
    font-size: .7rem; flex-shrink: 0;
}
#sidebar .sb-link:hover { background: rgba(255,255,255,.06); color: rgba(255,255,255,.82); }
#sidebar .sb-link.danger { color: rgba(220,80,80,.7); }
#sidebar .sb-link.danger:hover { background: rgba(214,48,49,.1); color: #ff7675; }
body.sidebar-collapsed #sidebar .sb-label { display: none; }
</style>

<nav id="sidebar" class="page-sidebar">
    <div id="sidebar-collapse">

        <ul id="side-menu" class="side-menu metismenu">

            <li class="<%= isActive(['home']) %>">
                <a href="/"><i class="sidebar-item-icon fa fa-home"></i><span class="nav-label">Dashboard</span></a>
            </li>

            <li class="heading">Bio Data</li>

            <li class="<%= isActive(['member_add','dependant_add']) %>">
                <a href="javascript:;">
                    <i class="sidebar-item-icon fa fa-user-plus"></i>
                    <span class="nav-label">Registration</span>
                    <i class="fa fa-angle-left arrow"></i>
                </a>
                <ul class="nav-2-level collapse">
                    <li><a class="<%= isActive(['member_add']) %>"    href="/member_add">Add Member</a></li>
                    <li><a class="<%= isActive(['dependant_add']) %>" href="/dependant_add">Add Dependant</a></li>
                </ul>
            </li>

            <li class="<%= isActive(['members','Dependants']) %>">
                <a href="javascript:;">
                    <i class="sidebar-item-icon fa fa-users"></i>
                    <span class="nav-label">Member Lists</span>
                    <i class="fa fa-angle-left arrow"></i>
                </a>
                <ul class="nav-2-level collapse">
                    <li><a class="<%= isActive(['members']) %>"    href="/members">Members</a></li>
                    <li><a class="<%= isActive(['Dependants']) %>" href="/Dependants">Dependants</a></li>
                </ul>
            </li>

            <li class="heading">Financials</li>

            <li class="<%= isActive(['transaction','internal_transaction','transaction_list','internal_transaction_listing']) %>">
                <a href="javascript:;">
                    <i class="sidebar-item-icon fa fa-exchange"></i>
                    <span class="nav-label">Transactions</span>
                    <i class="fa fa-angle-left arrow"></i>
                </a>
                <ul class="nav-2-level collapse">
                    <li><a class="<%= isActive(['transaction']) %>"                  href="/transaction">New Member Txn</a></li>
                    <li><a class="<%= isActive(['internal_transaction']) %>"         href="/internal_transaction">New Internal Txn</a></li>
                    <li><a class="<%= isActive(['transaction_list']) %>"             href="/transaction_list">Member Txn List</a></li>
                    <li><a class="<%= isActive(['internal_transaction_listing']) %>" href="/internal_transaction_listing">Internal Txn List</a></li>
                </ul>
            </li>

            <li class="<%= isActive(['loan_application','loan_list','loan_repayment','Loan_statement']) %>">
                <a href="javascript:;">
                    <i class="sidebar-item-icon fa fa-money"></i>
                    <span class="nav-label">Loans</span>
                    <i class="fa fa-angle-left arrow"></i>
                </a>
                <ul class="nav-2-level collapse">
                    <li><a class="<%= isActive(['loan_application']) %>" href="/loan_application">New Application</a></li>
                    <li><a class="<%= isActive(['loan_list']) %>"        href="/loan_list">Loan List</a></li>
                    <li><a class="<%= isActive(['loan_repayment']) %>"   href="/loan_repayment">Repayments</a></li>
                    <li><a class="<%= isActive(['Loan_statement']) %>"   href="/Loan_statement">Loan Statement</a></li>
                </ul>
            </li>

            <li class="heading">Reports</li>

            <li class="<%= isActive(['membership_fee','Welfare','Insurance_cover','savings_report','loans_report','liquidity_report','financial_statements']) %>">
                <a href="javascript:;">
                    <i class="sidebar-item-icon fa fa-file-text-o"></i>
                    <span class="nav-label">Reports</span>
                    <i class="fa fa-angle-left arrow"></i>
                </a>
                <ul class="nav-2-level collapse">
                    <li><a class="<%= isActive(['membership_fee']) %>"       href="/membership_fee">Membership Fee</a></li>
                    <li><a class="<%= isActive(['Welfare']) %>"              href="/Welfare">Welfare Fee</a></li>
                    <li><a class="<%= isActive(['Insurance_cover']) %>"      href="/Insurance_cover">Insurance Cover</a></li>
                    <li><a class="<%= isActive(['savings_report']) %>"       href="/savings_report">Savings Report</a></li>
                    <li><a class="<%= isActive(['loans_report']) %>"         href="/loans_report">Loans Report</a></li>
                    <li><a class="<%= isActive(['liquidity_report']) %>"     href="/liquidity_report">Liquidity Report</a></li>
                    <li><a class="<%= isActive(['financial_statements']) %>" href="/financial_statements">Financial Statements</a></li>
                </ul>
            </li>

            <li class="heading">Admin</li>

            <li class="<%= isActive(['users','user_add']) %>">
                <a href="javascript:;">
                    <i class="sidebar-item-icon fa fa-user-secret"></i>
                    <span class="nav-label">User Management</span>
                    <i class="fa fa-angle-left arrow"></i>
                </a>
                <ul class="nav-2-level collapse">
                    <li><a class="<%= isActive(['users']) %>"    href="/users">User List</a></li>
                    <li><a class="<%= isActive(['user_add']) %>" href="/user_add">Add User</a></li>
                </ul>
            </li>

        </ul>

        <div class="sb-bottom">
            <a href="/profile" class="sb-link">
                <span class="sb-ico"><i class="fa fa-user-o"></i></span><span class="sb-label">My Profile</span>
            </a>
            <a href="/settings" class="sb-link">
                <span class="sb-ico"><i class="fa fa-cog"></i></span><span class="sb-label">Settings</span>
            </a>
            <a href="/logout" class="sb-link danger">
                <span class="sb-ico"><i class="fa fa-power-off"></i></span><span class="sb-label">Sign Out</span>
            </a>
        </div>

    </div>
</nav>

<script>
(function () {
    function initSidebar() {
        if (typeof jQuery === 'undefined' || !jQuery.fn.metisMenu) {
            return setTimeout(initSidebar, 60);
        }
        var $menu = jQuery('#side-menu');
        if ($menu.data('metisMenu')) return;

        $menu.metisMenu({ toggle: true });

        /* Auto-open active parent */
        $menu.find('li.active').each(function () {
            var $sub = jQuery(this).children('ul.nav-2-level');
            if ($sub.length) {
                $sub.addClass('in').css('height', '');
                jQuery(this).children('a').attr('aria-expanded', 'true');
            }
        });
        $menu.find('ul.nav-2-level a.active').each(function () {
            var $sub = jQuery(this).closest('ul.nav-2-level');
            $sub.addClass('in').css('height', '');
            $sub.closest('li').children('a').attr('aria-expanded', 'true');
        });
    }

    document.readyState === 'loading'
        ? document.addEventListener('DOMContentLoaded', initSidebar)
        : initSidebar();
}());
</script>
