                    <li><a class="<%= isActive(['savings_report']) %>"     href="/savings_report">Savings Report</a></li>
                    <li><a class="<%= isActive(['loans_report']) %>"       href="/loans_report">Loans Report</a></li>
                    <li><a class="<%= isActive(['liquidity_report']) %>"   href="/liquidity_report">Liquidity Report</a></li>
