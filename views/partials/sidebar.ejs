<style>
/* ══════════════════════════════════════════
   SIDEBAR — matches header exactly
   Header height: 56px  |  Brand bg: #0f1623
   Accent: #00b894  |  Font: DM Sans
══════════════════════════════════════════ */
@import url('https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&display=swap');

/* ── Outer nav: sits BELOW the 56px header ── */
.page-sidebar {
    width: 240px;
    background: #0f1623;
    position: fixed;
    top: 56px;          /* flush under header */
    left: 0;
    bottom: 0;          /* fills to viewport bottom */
    z-index: 998;       /* below header (999) */
    display: flex;
    flex-direction: column;
    overflow: hidden;   /* clip horizontally only */
    font-family: 'DM Sans', sans-serif;
    border-right: 1px solid rgba(255,255,255,.05);
}

/* ── Inner scroll container fills remaining height ── */
#sidebar-collapse {
    display: flex;
    flex-direction: column;
    flex: 1;
    min-height: 0;      /* CRITICAL — lets flex child shrink & scroll */
    overflow-y: auto;
    overflow-x: hidden;
    scrollbar-width: thin;
    scrollbar-color: rgba(255,255,255,.12) transparent;
}
#sidebar-collapse::-webkit-scrollbar       { width: 3px; }
#sidebar-collapse::-webkit-scrollbar-thumb { background: rgba(255,255,255,.12); border-radius: 4px; }

/* ── NAV takes all remaining height so bottom dock sticks ── */
.side-menu {
    list-style: none;
    padding: 4px 8px 8px;
    margin: 0;
    flex: 1;            /* pushes .sb-bottom to bottom */
}

/* ── Section headings ── */
.side-menu .heading {
    font-size: .57rem;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    color: rgba(255,255,255,.2);
    padding: 13px 8px 4px;
    pointer-events: none;
    user-select: none;
}

/* ── Top-level links ── */
.side-menu > li > a {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 8px 9px;
    border-radius: 8px;
    color: rgba(255,255,255,.52);
    font-size: .78rem;
    font-weight: 500;
    text-decoration: none !important;
    transition: background .14s, color .14s;
    position: relative;
    margin-bottom: 1px;
    white-space: nowrap;
    overflow: hidden;
}
.side-menu > li > a:hover {
    background: rgba(255,255,255,.06);
    color: rgba(255,255,255,.88);
}

/* Active parent */
.side-menu > li.active > a {
    background: rgba(0,184,148,.13);
    color: #00b894;
}
.side-menu > li.active > a::after {
    content: '';
    position: absolute;
    left: 0; top: 18%; bottom: 18%;
    width: 3px;
    border-radius: 0 3px 3px 0;
    background: #00b894;
}

/* ── Icon pills ── */
.sidebar-item-icon {
    width: 26px; height: 26px;
    border-radius: 7px;
    background: rgba(255,255,255,.05);
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    font-size: .76rem;
    flex-shrink: 0;
    transition: background .14s, color .14s;
}
.side-menu > li > a:hover .sidebar-item-icon {
    background: rgba(255,255,255,.09);
}
.side-menu > li.active > a .sidebar-item-icon {
    background: rgba(0,184,148,.18);
    color: #00b894;
}

/* ── Chevron arrow ── */
.side-menu .arrow {
    margin-left: auto;
    font-size: .58rem;
    color: rgba(255,255,255,.18);
    transition: transform .18s, color .14s;
    flex-shrink: 0;
}
.side-menu > li > a[aria-expanded="true"] .arrow {
    transform: rotate(-90deg);
    color: rgba(255,255,255,.4);
}
.side-menu > li.active > a .arrow {
    color: rgba(0,184,148,.55);
}

/* ── Submenu ── */
.side-menu .nav-2-level {
    list-style: none;
    padding: 2px 0 4px 13px;
    margin: 0;
    overflow: hidden;
}
.side-menu .nav-2-level li a {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 6px 9px;
    border-radius: 7px;
    color: rgba(255,255,255,.38);
    font-size: .73rem;
    font-weight: 400;
    text-decoration: none !important;
    transition: background .12s, color .12s;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}
.side-menu .nav-2-level li a::before {
    content: '';
    width: 4px; height: 4px;
    border-radius: 50%;
    background: rgba(255,255,255,.15);
    flex-shrink: 0;
    transition: background .12s, transform .12s;
}
.side-menu .nav-2-level li a:hover {
    color: rgba(255,255,255,.82);
    background: rgba(255,255,255,.04);
}
.side-menu .nav-2-level li a:hover::before {
    background: rgba(255,255,255,.45);
}
.side-menu .nav-2-level li a.active {
    color: #00b894;
    background: rgba(0,184,148,.08);
    font-weight: 500;
}
.side-menu .nav-2-level li a.active::before {
    background: #00b894;
    transform: scale(1.4);
}

/* Metismenu collapse */
.side-menu .nav-2-level.collapse         { display: none; }
.side-menu .nav-2-level.collapse.in,
.side-menu .nav-2-level.collapsing       { display: block; }

/* ── Bottom dock — always visible at bottom ── */
.sb-bottom {
    padding: 8px;
    border-top: 1px solid rgba(255,255,255,.06);
    display: flex;
    flex-direction: column;
    gap: 1px;
    flex-shrink: 0;     /* never squash */
}
.sb-bottom__link {
    display: flex;
    align-items: center;
    gap: 9px;
    padding: 7px 9px;
    border-radius: 8px;
    color: rgba(255,255,255,.38);
    font-size: .74rem;
    font-weight: 500;
    text-decoration: none !important;
    transition: background .12s, color .12s;
}
.sb-bottom__link .sb-ico {
    width: 24px; height: 24px;
    border-radius: 6px;
    background: rgba(255,255,255,.04);
    display: flex; align-items: center; justify-content: center;
    font-size: .7rem; flex-shrink: 0;
    transition: background .12s, color .12s;
}
.sb-bottom__link:hover {
    background: rgba(255,255,255,.05);
    color: rgba(255,255,255,.82);
}
.sb-bottom__link:hover .sb-ico {
    background: rgba(255,255,255,.08);
}
.sb-bottom__link--danger { color: rgba(220,80,80,.7); }
.sb-bottom__link--danger .sb-ico { color: rgba(220,80,80,.7); }
.sb-bottom__link--danger:hover {
    background: rgba(214,48,49,.1);
    color: #ff7675;
}
.sb-bottom__link--danger:hover .sb-ico {
    background: rgba(214,48,49,.12);
    color: #ff7675;
}

/* ── Profile block (no longer at top — removed; header handles user identity) ── */
/* Keep a slim top spacer so first nav item isn't flush to edge */
.sb-top-pad { height: 6px; flex-shrink: 0; }
</style>

